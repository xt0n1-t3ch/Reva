{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reva.local/contracts/extraction-result.schema.json",
  "title": "ExtractionResult",
  "type": "object",
  "required": ["documentId", "documentType", "confidence", "fields", "tables", "schemaMappings", "exceptions"],
  "properties": {
    "documentId": { "type": "string", "format": "uuid" },
    "documentType": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "fields": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "value", "confidence"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "value": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "source": { "type": "string" }
        }
      }
    },
    "tables": { "type": "array" },
    "schemaMappings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["senderKey", "sourceHeader", "canonicalField", "normalizedValue", "confidence", "source", "isLearned", "isCorrected"],
        "properties": {
          "senderKey": { "type": "string" },
          "sourceHeader": { "type": "string", "minLength": 1 },
          "canonicalField": { "type": "string" },
          "normalizedValue": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "source": { "type": "string", "enum": ["learned", "alias", "fuzzy", "unmapped"] },
          "isLearned": { "type": "boolean" },
          "isCorrected": { "type": "boolean" }
        }
      }
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "message"],
        "properties": {
          "severity": { "type": "string", "enum": ["Info", "Warning", "Critical"] },
          "message": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
