<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:onb="using:Reva.App.Onboarding"
             x:Class="Reva.App.Onboarding.TourOverlay"
             x:DataType="onb:TourOverlayViewModel"
             x:CompileBindings="True"
             IsVisible="{Binding IsVisible}"
             IsHitTestVisible="True">

    <Grid>

        <Canvas IsVisible="{Binding HasHighlight}" IsHitTestVisible="True">
            <Border Canvas.Left="0" Canvas.Top="0"
                    Width="{Binding SurfaceWidth}"
                    Height="{Binding DimTopHeight}"
                    Background="{DynamicResource ScrimBrush}" />
            <Border Canvas.Left="0"
                    Canvas.Top="{Binding DimBottomY}"
                    Width="{Binding SurfaceWidth}"
                    Height="{Binding DimBottomHeight}"
                    Background="{DynamicResource ScrimBrush}" />
            <Border Canvas.Left="0"
                    Canvas.Top="{Binding DimMiddleY}"
                    Width="{Binding DimLeftWidth}"
                    Height="{Binding DimMiddleHeight}"
                    Background="{DynamicResource ScrimBrush}" />
            <Border Canvas.Left="{Binding DimRightX}"
                    Canvas.Top="{Binding DimMiddleY}"
                    Width="{Binding DimRightWidth}"
                    Height="{Binding DimMiddleHeight}"
                    Background="{DynamicResource ScrimBrush}" />
            <Border Canvas.Left="{Binding HighlightX}"
                    Canvas.Top="{Binding HighlightY}"
                    Width="{Binding HighlightWidth}"
                    Height="{Binding HighlightHeight}"
                    CornerRadius="{Binding HighlightCornerRadiusValue}"
                    Background="Transparent"
                    BorderThickness="2"
                    BorderBrush="{DynamicResource AccentBrush}"
                    BoxShadow="{DynamicResource AccentGlow}"
                    IsHitTestVisible="False" />
        </Canvas>

        <Border IsVisible="{Binding !HasHighlight}"
                Background="{DynamicResource ScrimBrush}" />

        <Border Classes="glassStrong"
                Padding="0"
                Width="{Binding CardWidthValue}"
                BoxShadow="{DynamicResource AccentGlow}"
                VerticalAlignment="{Binding CardCentered, Converter={x:Static onb:TourCenteredVerticalAlignmentConverter.Instance}}"
                HorizontalAlignment="{Binding CardCentered, Converter={x:Static onb:TourCenteredHorizontalAlignmentConverter.Instance}}"
                Margin="{Binding CardMargin}">
            <Border CornerRadius="{DynamicResource CornerRadiusXl}"
                    Background="{DynamicResource GlassStrongBrush}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1"
                    Padding="24"
                    ClipToBounds="True">
                <StackPanel Spacing="18">

                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="11" VerticalAlignment="Center">
                            <Border Classes="logoChip" Width="30" Height="30">
                                <TextBlock Text="R"
                                           FontWeight="Bold"
                                           FontSize="{DynamicResource FontSizeBody}"
                                           Foreground="{DynamicResource AccentForegroundBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <Border Classes="badge info"
                                    IsVisible="{Binding HasStepProgress}">
                                <TextBlock Text="{Binding Counter}" />
                            </Border>
                        </StackPanel>

                        <TextBlock Text="{Binding Title}"
                                   Classes="heading"
                                   FontSize="{DynamicResource FontSizeSubheading}"
                                   TextWrapping="Wrap" />

                        <TextBlock Text="{Binding Body}"
                                   Classes="muted"
                                   LineHeight="21"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="8" IsVisible="{Binding HasStepProgress}">
                        <ProgressBar Minimum="0"
                                     Maximum="{Binding StepTotal}"
                                     Value="{Binding StepProgress}"
                                     Height="5"
                                     CornerRadius="{DynamicResource CornerRadiusPill}"
                                     Background="{DynamicResource Surface3Brush}"
                                     Foreground="{DynamicResource AccentBrush}" />
                    </StackPanel>

                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                        <Button Grid.Column="0"
                                Classes="ghost"
                                Content="Skip"
                                Command="{Binding SkipCommand}" />
                        <Button Grid.Column="2"
                                Classes="secondary"
                                Content="Back"
                                Margin="0 0 10 0"
                                IsEnabled="{Binding CanGoBack}"
                                Command="{Binding BackCommand}" />
                        <Button Grid.Column="3"
                                Classes="primary"
                                Content="{Binding PrimaryActionText}"
                                Command="{Binding NextCommand}" />
                    </Grid>

                </StackPanel>
            </Border>
        </Border>

    </Grid>
</UserControl>
