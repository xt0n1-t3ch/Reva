<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="Window">
        <Setter Property="Background" Value="{DynamicResource CanvasBrush}" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="TransparencyLevelHint" Value="Mica, AcrylicBlur, Blur" />
    </Style>

    <Style Selector="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="Foreground" Value="{DynamicResource BodyForegroundBrush}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="TextBlock.pageTitle">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeHeading}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="LineHeight" Value="32" />
    </Style>

    <Style Selector="TextBlock.display">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeDisplay}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
    </Style>

    <Style Selector="TextBlock.heading">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeHeading}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
    </Style>

    <Style Selector="TextBlock.subheading">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSubheading}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
    </Style>

    <Style Selector="TextBlock.eyebrow">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeEyebrow}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}" />
        <Setter Property="LetterSpacing" Value="1.2" />
    </Style>

    <Style Selector="TextBlock.muted">
        <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
    </Style>

    <Style Selector="TextBlock.caption">
        <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeCaption}" />
    </Style>

    <Style Selector="TextBlock.kpiValue">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeKpi}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="FontFeatures" Value="tnum=1" />
    </Style>

    <Style Selector="Border.glass">
        <Setter Property="Background" Value="{DynamicResource GlassBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusLg}" />
        <Setter Property="BoxShadow" Value="{DynamicResource ShadowGlass}" />
    </Style>

    <Style Selector="Border.glassStrong">
        <Setter Property="Background" Value="{DynamicResource GlassStrongBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusXl}" />
        <Setter Property="BoxShadow" Value="{DynamicResource ShadowGlass}" />
    </Style>

    <Style Selector="Border.hero">
        <Setter Property="Background" Value="{DynamicResource HeroWashBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusXl}" />
        <Setter Property="Padding" Value="{DynamicResource SpacingCard}" />
        <Setter Property="BoxShadow" Value="{DynamicResource ShadowCard}" />
    </Style>

    <Style Selector="Border.scrim">
        <Setter Property="Background" Value="{DynamicResource ScrimBrush}" />
    </Style>

    <Style Selector="Border.card">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusLg}" />
        <Setter Property="Padding" Value="{DynamicResource SpacingCard}" />
        <Setter Property="BoxShadow" Value="{DynamicResource ShadowCard}" />
        <Setter Property="Transitions">
            <Transitions>
                <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.18" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.card:pointerover">
        <Setter Property="BoxShadow" Value="{DynamicResource ShadowHover}" />
    </Style>

    <Style Selector="Border.kpi">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusLg}" />
        <Setter Property="Padding" Value="22" />
        <Setter Property="BoxShadow" Value="{DynamicResource ShadowCard}" />
        <Setter Property="Transitions">
            <Transitions>
                <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.18" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.kpi:pointerover">
        <Setter Property="BoxShadow" Value="{DynamicResource ShadowHover}" />
    </Style>

    <Style Selector="Border.panel">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusLg}" />
    </Style>

    <Style Selector="Border.chip">
        <Setter Property="Background" Value="{DynamicResource Surface2Brush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}" />
        <Setter Property="Padding" Value="12 6" />
    </Style>

    <Style Selector="Border.iconChip">
        <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusMd}" />
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="34" />
    </Style>

    <Style Selector="Border.logoChip">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusMd}" />
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
    </Style>

    <Style Selector="Button.primary">
        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryForegroundBrush}" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
        <Setter Property="Height" Value="38" />
        <Setter Property="Padding" Value="18 0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.primary /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryForegroundBrush}" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
                <BrushTransition Property="Foreground" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
    </Style>
    <Style Selector="Button.primary:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
    </Style>

    <Style Selector="Button.accent">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
        <Setter Property="Height" Value="38" />
        <Setter Property="Padding" Value="18 0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.accent /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
                <BrushTransition Property="Foreground" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryForegroundBrush}" />
    </Style>

    <Style Selector="Button.secondary">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
        <Setter Property="Height" Value="38" />
        <Setter Property="Padding" Value="18 0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.secondary /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.secondary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Surface3Brush}" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
    </Style>

    <Style Selector="Button.ghost">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
        <Setter Property="Height" Value="38" />
        <Setter Property="Padding" Value="16 0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.ghost /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
                <BrushTransition Property="Foreground" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Surface3Brush}" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
    </Style>

    <Style Selector="Button.nav">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Padding" Value="14 10" />
        <Setter Property="Margin" Value="0 2" />
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusMd}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.nav /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
                <BrushTransition Property="Foreground" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Surface3Brush}" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
    </Style>
    <Style Selector="Button.nav.active">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.nav.active /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="3 0 0 0" />
    </Style>
    <Style Selector="Button.nav.active:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="Button.icon">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="Padding" Value="9" />
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusMd}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.icon /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
                <BrushTransition Property="Foreground" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.icon:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Surface3Brush}" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
    </Style>

    <Style Selector="Border.statusDot">
        <Setter Property="Width" Value="8" />
        <Setter Property="Height" Value="8" />
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.badge">
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}" />
        <Setter Property="Padding" Value="10 4" />
        <Setter Property="Background" Value="{DynamicResource Surface3Brush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.badge > TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeEyebrow}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.badge.success">
        <Setter Property="Background" Value="{DynamicResource SuccessSoftBrush}" />
    </Style>
    <Style Selector="Border.badge.success > TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
    </Style>
    <Style Selector="Border.badge.warning">
        <Setter Property="Background" Value="{DynamicResource WarningSoftBrush}" />
    </Style>
    <Style Selector="Border.badge.warning > TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
    </Style>
    <Style Selector="Border.badge.danger">
        <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}" />
    </Style>
    <Style Selector="Border.badge.danger > TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
    </Style>
    <Style Selector="Border.badge.info">
        <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
    </Style>
    <Style Selector="Border.badge.info > TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="Border.badge.neutral">
        <Setter Property="Background" Value="{DynamicResource Surface3Brush}" />
    </Style>
    <Style Selector="Border.badge.neutral > TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}" />
    </Style>

    <Style Selector="TextBox">
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="Background" Value="{DynamicResource Surface2Brush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusMd}" />
        <Setter Property="Padding" Value="12 9" />
        <Setter Property="MinHeight" Value="38" />
    </Style>
    <Style Selector="TextBox /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource Surface2Brush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusMd}" />
    </Style>
    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource Surface2Brush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="TextBox /template/ TextBlock#PART_Watermark">
        <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}" />
    </Style>

    <Style Selector="ComboBox">
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="Background" Value="{DynamicResource Surface2Brush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusMd}" />
        <Setter Property="Padding" Value="12 8" />
        <Setter Property="MinHeight" Value="38" />
    </Style>
    <Style Selector="ComboBox /template/ Border#Background">
        <Setter Property="Background" Value="{DynamicResource Surface2Brush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusMd}" />
    </Style>
    <Style Selector="ComboBox:pointerover /template/ Border#Background">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
        <Setter Property="Background" Value="{DynamicResource Surface2Brush}" />
    </Style>
    <Style Selector="ComboBox:focus /template/ Border#Background">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    </Style>
    <Style Selector="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="Padding" Value="12 8" />
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusSm}" />
    </Style>
    <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Surface3Brush}" />
    </Style>
    <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="DataGrid">
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource BodyForegroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="GridLinesVisibility" Value="None" />
        <Setter Property="RowBackground" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Surface3Brush}" />
        <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
        <Setter Property="RowHeight" Value="48" />
    </Style>
    <Style Selector="DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeEyebrow}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="SeparatorBrush" Value="Transparent" />
        <Setter Property="Padding" Value="14 10" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="0 0 0 1" />
    </Style>
    <Style Selector="DataGridRow">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
    </Style>
    <Style Selector="DataGridRow:pointerover /template/ DataGridCellsPresenter">
        <Setter Property="Background" Value="{DynamicResource Surface2Brush}" />
    </Style>
    <Style Selector="DataGridRow:selected /template/ DataGridCellsPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
    </Style>
    <Style Selector="DataGridCell">
        <Setter Property="Foreground" Value="{DynamicResource BodyForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Surface3Brush}" />
        <Setter Property="BorderThickness" Value="0 0 0 1" />
        <Setter Property="Padding" Value="14 0" />
        <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
    </Style>
    <Style Selector="DataGridCell:focus /template/ Grid#FocusVisual">
        <Setter Property="IsVisible" Value="False" />
    </Style>

    <Style Selector="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ScrollBar:vertical">
        <Setter Property="Width" Value="8" />
    </Style>
    <Style Selector="ScrollBar:horizontal">
        <Setter Property="Height" Value="8" />
    </Style>
    <Style Selector="ScrollBar /template/ Thumb">
        <Setter Property="Background" Value="{DynamicResource BorderBrush}" />
        <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusPill}" />
    </Style>
    <Style Selector="ScrollBar /template/ Thumb:pointerover">
        <Setter Property="Background" Value="{DynamicResource MutedForegroundBrush}" />
    </Style>

</Styles>
