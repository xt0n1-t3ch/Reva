<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>

        <ResourceDictionary x:Key="Light">
            <LinearGradientBrush x:Key="BgBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Offset="0" Color="#EEF2FF" />
                <GradientStop Offset="0.5" Color="#F3F1FA" />
                <GradientStop Offset="1" Color="#FBF7FF" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="CanvasBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Offset="0" Color="#EEF2FF" />
                <GradientStop Offset="0.5" Color="#F3F1FA" />
                <GradientStop Offset="1" Color="#FBF7FF" />
            </LinearGradientBrush>

            <SolidColorBrush x:Key="SurfaceBrush" Color="#F2FFFFFF" />
            <SolidColorBrush x:Key="Surface2Brush" Color="#D9FFFFFF" />
            <SolidColorBrush x:Key="Surface3Brush" Color="#C2EEF1FA" />
            <SolidColorBrush x:Key="BorderBrush" Color="#1A0B1020" />

            <SolidColorBrush x:Key="GlassBrush" Color="#BFFFFFFF" />
            <SolidColorBrush x:Key="GlassStrongBrush" Color="#E6FFFFFF" />
            <SolidColorBrush x:Key="GlassBorderBrush" Color="#99FFFFFF" />
            <SolidColorBrush x:Key="ScrimBrush" Color="#400B1020" />

            <SolidColorBrush x:Key="ForegroundBrush" Color="#0B1020" />
            <SolidColorBrush x:Key="BodyForegroundBrush" Color="#39404F" />
            <SolidColorBrush x:Key="MutedForegroundBrush" Color="#6B7280" />

            <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB" />
            <SolidColorBrush x:Key="PrimaryForegroundBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="PrimarySoftBrush" Color="#1A2563EB" />

            <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
            <SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="AccentSoftBrush" Color="#1A2563EB" />
            <SolidColorBrush x:Key="AccentBorderBrush" Color="#592563EB" />

            <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Offset="0" Color="#2563EB" />
                <GradientStop Offset="1" Color="#4F46E5" />
            </LinearGradientBrush>

            <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A" />
            <SolidColorBrush x:Key="SuccessSoftBrush" Color="#1A16A34A" />
            <SolidColorBrush x:Key="WarningBrush" Color="#B45309" />
            <SolidColorBrush x:Key="WarningSoftBrush" Color="#1AB45309" />
            <SolidColorBrush x:Key="DangerBrush" Color="#DC2626" />
            <SolidColorBrush x:Key="DangerSoftBrush" Color="#1ADC2626" />

            <SolidColorBrush x:Key="ChartGridBrush" Color="#140B1020" />

            <LinearGradientBrush x:Key="HeroWashBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Offset="0" Color="#262563EB" />
                <GradientStop Offset="0.5" Color="#1A4F46E5" />
                <GradientStop Offset="1" Color="#14818CF8" />
            </LinearGradientBrush>

            <BoxShadows x:Key="AccentGlow">0 8 26 -6 #592563EB</BoxShadows>
        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">
            <LinearGradientBrush x:Key="BgBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Offset="0" Color="#0A0E1A" />
                <GradientStop Offset="0.5" Color="#0B1020" />
                <GradientStop Offset="1" Color="#0A0F1E" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="CanvasBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Offset="0" Color="#0A0E1A" />
                <GradientStop Offset="0.5" Color="#0B1020" />
                <GradientStop Offset="1" Color="#0A0F1E" />
            </LinearGradientBrush>

            <SolidColorBrush x:Key="SurfaceBrush" Color="#12FFFFFF" />
            <SolidColorBrush x:Key="Surface2Brush" Color="#0DFFFFFF" />
            <SolidColorBrush x:Key="Surface3Brush" Color="#1AFFFFFF" />
            <SolidColorBrush x:Key="BorderBrush" Color="#24FFFFFF" />

            <SolidColorBrush x:Key="GlassBrush" Color="#14FFFFFF" />
            <SolidColorBrush x:Key="GlassStrongBrush" Color="#1FFFFFFF" />
            <SolidColorBrush x:Key="GlassBorderBrush" Color="#24FFFFFF" />
            <SolidColorBrush x:Key="ScrimBrush" Color="#99060912" />

            <SolidColorBrush x:Key="ForegroundBrush" Color="#F1F5F9" />
            <SolidColorBrush x:Key="BodyForegroundBrush" Color="#CBD5E1" />
            <SolidColorBrush x:Key="MutedForegroundBrush" Color="#8593A8" />

            <SolidColorBrush x:Key="PrimaryBrush" Color="#3B82F6" />
            <SolidColorBrush x:Key="PrimaryForegroundBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="PrimarySoftBrush" Color="#2E3B82F6" />

            <SolidColorBrush x:Key="AccentBrush" Color="#3B82F6" />
            <SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="AccentSoftBrush" Color="#2E3B82F6" />
            <SolidColorBrush x:Key="AccentBorderBrush" Color="#663B82F6" />

            <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Offset="0" Color="#3B82F6" />
                <GradientStop Offset="1" Color="#6366F1" />
            </LinearGradientBrush>

            <SolidColorBrush x:Key="SuccessBrush" Color="#34D399" />
            <SolidColorBrush x:Key="SuccessSoftBrush" Color="#2634D399" />
            <SolidColorBrush x:Key="WarningBrush" Color="#FBBF24" />
            <SolidColorBrush x:Key="WarningSoftBrush" Color="#26FBBF24" />
            <SolidColorBrush x:Key="DangerBrush" Color="#F87171" />
            <SolidColorBrush x:Key="DangerSoftBrush" Color="#26F87171" />

            <SolidColorBrush x:Key="ChartGridBrush" Color="#1AFFFFFF" />

            <LinearGradientBrush x:Key="HeroWashBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Offset="0" Color="#3D3B82F6" />
                <GradientStop Offset="0.5" Color="#266366F1" />
                <GradientStop Offset="1" Color="#14818CF8" />
            </LinearGradientBrush>

            <BoxShadows x:Key="AccentGlow">0 8 30 -4 #803B82F6</BoxShadows>
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

    <CornerRadius x:Key="CornerRadiusSm">8</CornerRadius>
    <CornerRadius x:Key="CornerRadiusMd">12</CornerRadius>
    <CornerRadius x:Key="CornerRadiusLg">18</CornerRadius>
    <CornerRadius x:Key="CornerRadiusXl">22</CornerRadius>
    <CornerRadius x:Key="CornerRadiusPill">999</CornerRadius>

    <Thickness x:Key="SpacingCard">24</Thickness>
    <Thickness x:Key="SpacingTight">12</Thickness>

    <BoxShadows x:Key="ShadowNone">none</BoxShadows>
    <BoxShadows x:Key="ShadowCard">0 1 1 0 #0F0B1020, 0 12 32 -10 #1A0B1020</BoxShadows>
    <BoxShadows x:Key="ShadowSoft">0 1 2 0 #0A0B1020, 0 6 18 -10 #120B1020</BoxShadows>
    <BoxShadows x:Key="ShadowGlass">0 1 0 0 #66FFFFFF, 0 2 8 -2 #140B1020, 0 20 50 -16 #240B1020</BoxShadows>
    <BoxShadows x:Key="ShadowHover">0 2 4 0 #140B1020, 0 20 48 -12 #2B0B1020</BoxShadows>

    <FontFamily x:Key="AppFontFamily">fonts:Inter#Inter</FontFamily>

    <x:Double x:Key="FontSizeEyebrow">11</x:Double>
    <x:Double x:Key="FontSizeCaption">12</x:Double>
    <x:Double x:Key="FontSizeBody">14</x:Double>
    <x:Double x:Key="FontSizeSubheading">16</x:Double>
    <x:Double x:Key="FontSizeHeading">22</x:Double>
    <x:Double x:Key="FontSizeDisplay">34</x:Double>
    <x:Double x:Key="FontSizeKpi">40</x:Double>
</ResourceDictionary>
