<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>

        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="BgBrush" Color="#FFF3F1F0" />
            <SolidColorBrush x:Key="CanvasBrush" Color="#E6F3F1F0" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="Surface2Brush" Color="#FFFAF9F8" />
            <SolidColorBrush x:Key="Surface3Brush" Color="#FFF1EFED" />
            <SolidColorBrush x:Key="BorderBrush" Color="#FFE7E4E1" />

            <SolidColorBrush x:Key="GlassBrush" Color="#C7FFFFFF" />
            <SolidColorBrush x:Key="GlassStrongBrush" Color="#EBFFFFFF" />
            <SolidColorBrush x:Key="GlassBorderBrush" Color="#D9FFFFFF" />
            <SolidColorBrush x:Key="ScrimBrush" Color="#40000000" />

            <SolidColorBrush x:Key="ForegroundBrush" Color="#FF05051E" />
            <SolidColorBrush x:Key="BodyForegroundBrush" Color="#FF3A3A45" />
            <SolidColorBrush x:Key="MutedForegroundBrush" Color="#FF6B6A73" />

            <SolidColorBrush x:Key="PrimaryBrush" Color="#FF05051E" />
            <SolidColorBrush x:Key="PrimaryForegroundBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="PrimarySoftBrush" Color="#FFEAF1FE" />

            <SolidColorBrush x:Key="AccentBrush" Color="#FF2563EB" />
            <SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="AccentSoftBrush" Color="#FFEAF1FE" />
            <SolidColorBrush x:Key="AccentBorderBrush" Color="#FFC9DCFB" />

            <SolidColorBrush x:Key="SuccessBrush" Color="#FF16A34A" />
            <SolidColorBrush x:Key="SuccessSoftBrush" Color="#FFE7F6EC" />
            <SolidColorBrush x:Key="WarningBrush" Color="#FFB45309" />
            <SolidColorBrush x:Key="WarningSoftBrush" Color="#FFFBEFD8" />
            <SolidColorBrush x:Key="DangerBrush" Color="#FFDC2626" />
            <SolidColorBrush x:Key="DangerSoftBrush" Color="#FFFBE9E9" />

            <SolidColorBrush x:Key="ChartGridBrush" Color="#FFECEAE8" />

            <LinearGradientBrush x:Key="HeroWashBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Offset="0" Color="#FFEAF1FE" />
                <GradientStop Offset="0.55" Color="#FFF7F9FD" />
                <GradientStop Offset="1" Color="#FFFAF9F8" />
            </LinearGradientBrush>
        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="BgBrush" Color="#FF0E1117" />
            <SolidColorBrush x:Key="CanvasBrush" Color="#D90E1117" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="#FF161B22" />
            <SolidColorBrush x:Key="Surface2Brush" Color="#FF1B212B" />
            <SolidColorBrush x:Key="Surface3Brush" Color="#FF232A34" />
            <SolidColorBrush x:Key="BorderBrush" Color="#FF232A34" />

            <SolidColorBrush x:Key="GlassBrush" Color="#C71B212B" />
            <SolidColorBrush x:Key="GlassStrongBrush" Color="#E61B212B" />
            <SolidColorBrush x:Key="GlassBorderBrush" Color="#26FFFFFF" />
            <SolidColorBrush x:Key="ScrimBrush" Color="#59000000" />

            <SolidColorBrush x:Key="ForegroundBrush" Color="#FFE6E8EC" />
            <SolidColorBrush x:Key="BodyForegroundBrush" Color="#FFC4C8D2" />
            <SolidColorBrush x:Key="MutedForegroundBrush" Color="#FF8B93A1" />

            <SolidColorBrush x:Key="PrimaryBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="PrimaryForegroundBrush" Color="#FF05051E" />
            <SolidColorBrush x:Key="PrimarySoftBrush" Color="#FF1C2740" />

            <SolidColorBrush x:Key="AccentBrush" Color="#FF3B82F6" />
            <SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="AccentSoftBrush" Color="#FF18233A" />
            <SolidColorBrush x:Key="AccentBorderBrush" Color="#FF2C4470" />

            <SolidColorBrush x:Key="SuccessBrush" Color="#FF34D399" />
            <SolidColorBrush x:Key="SuccessSoftBrush" Color="#FF143226" />
            <SolidColorBrush x:Key="WarningBrush" Color="#FFF59E0B" />
            <SolidColorBrush x:Key="WarningSoftBrush" Color="#FF35290F" />
            <SolidColorBrush x:Key="DangerBrush" Color="#FFF87171" />
            <SolidColorBrush x:Key="DangerSoftBrush" Color="#FF3A1C1C" />

            <SolidColorBrush x:Key="ChartGridBrush" Color="#FF232A34" />

            <LinearGradientBrush x:Key="HeroWashBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Offset="0" Color="#FF18233A" />
                <GradientStop Offset="0.55" Color="#FF161D29" />
                <GradientStop Offset="1" Color="#FF1B212B" />
            </LinearGradientBrush>
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

    <CornerRadius x:Key="CornerRadiusSm">8</CornerRadius>
    <CornerRadius x:Key="CornerRadiusMd">10</CornerRadius>
    <CornerRadius x:Key="CornerRadiusLg">16</CornerRadius>
    <CornerRadius x:Key="CornerRadiusXl">20</CornerRadius>
    <CornerRadius x:Key="CornerRadiusPill">999</CornerRadius>

    <Thickness x:Key="SpacingCard">24</Thickness>
    <Thickness x:Key="SpacingTight">12</Thickness>

    <BoxShadows x:Key="ShadowCard">0 1 2 0 #0F000000, 0 10 30 -8 #14000000</BoxShadows>
    <BoxShadows x:Key="ShadowSoft">0 1 2 0 #0A000000, 0 6 18 -8 #10000000</BoxShadows>
    <BoxShadows x:Key="ShadowGlass">0 1 1 0 #14FFFFFF, 0 2 6 -2 #14000000, 0 18 44 -12 #1F000000</BoxShadows>
    <BoxShadows x:Key="ShadowHover">0 2 4 0 #12000000, 0 16 40 -10 #1F000000</BoxShadows>

    <FontFamily x:Key="AppFontFamily">fonts:Inter#Inter</FontFamily>

    <x:Double x:Key="FontSizeEyebrow">11</x:Double>
    <x:Double x:Key="FontSizeCaption">12</x:Double>
    <x:Double x:Key="FontSizeBody">14</x:Double>
    <x:Double x:Key="FontSizeSubheading">15</x:Double>
    <x:Double x:Key="FontSizeHeading">26</x:Double>
    <x:Double x:Key="FontSizeDisplay">26</x:Double>
    <x:Double x:Key="FontSizeKpi">32</x:Double>
</ResourceDictionary>
