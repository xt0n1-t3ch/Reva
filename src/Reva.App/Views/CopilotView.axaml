<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Reva.App.ViewModels"
             xmlns:conv="using:Reva.App.Converters"
             x:Class="Reva.App.Views.CopilotView"
             x:DataType="vm:CopilotViewModel"
             x:CompileBindings="True">

    <UserControl.Resources>
        <x:Double x:Key="CopilotBubbleMaxWidth">340</x:Double>
    </UserControl.Resources>

    <UserControl.Styles>

        <Style Selector="Border.bubble">
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusLg}" />
            <Setter Property="Padding" Value="16 13" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MaxWidth" Value="{StaticResource CopilotBubbleMaxWidth}" />
        </Style>

        <Style Selector="Border.bubble.user">
            <Setter Property="Background" Value="{DynamicResource AccentGradientBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="BoxShadow" Value="{DynamicResource AccentGlow}" />
        </Style>
        <Style Selector="Border.bubble.user SelectableTextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
        </Style>

        <Style Selector="Border.bubble.assistant">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="BoxShadow" Value="{DynamicResource ShadowGlass}" />
        </Style>
        <Style Selector="Border.bubble.assistant SelectableTextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        </Style>

        <Style Selector="Border.avatar">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusMd}" />
            <Setter Property="Background" Value="{DynamicResource AccentGradientBrush}" />
            <Setter Property="BoxShadow" Value="{DynamicResource AccentGlow}" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
        <Style Selector="Border.avatar TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="Border.stepChip">
            <Setter Property="Background" Value="{DynamicResource Surface2Brush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusMd}" />
            <Setter Property="Padding" Value="12 10" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="MaxWidth" Value="{StaticResource CopilotBubbleMaxWidth}" />
            <Setter Property="BoxShadow" Value="{DynamicResource ShadowSoft}" />
        </Style>

        <Style Selector="Border.stepIcon">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusSm}" />
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
        <Style Selector="Border.stepIcon TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="Ellipse.thinkingDot">
            <Setter Property="Width" Value="7" />
            <Setter Property="Height" Value="7" />
            <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="Button.suggestion">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource BodyForegroundBrush}" />
            <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.suggestion /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource GlassBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusMd}" />
            <Setter Property="Padding" Value="15 13" />
            <Setter Property="BoxShadow" Value="{DynamicResource ShadowSoft}" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.suggestion:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource AccentBrush}" />
        </Style>

        <Style Selector="TextBox.composer">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
            <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusMd}" />
            <Setter Property="Padding" Value="15 13" />
            <Setter Property="MinHeight" Value="52" />
            <Setter Property="MaxHeight" Value="140" />
        </Style>
        <Style Selector="TextBox.composer /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}" />
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusMd}" />
        </Style>
        <Style Selector="TextBox.composer:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BoxShadow" Value="{DynamicResource AccentGlow}" />
        </Style>

    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto,Auto" Background="Transparent">

        <Border Grid.Row="0"
                Classes="glass"
                CornerRadius="0"
                BorderThickness="0 0 0 1"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                Padding="24 18">
            <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                    <Border Classes="logoChip" VerticalAlignment="Center">
                        <TextBlock Text="✦"
                                   FontSize="17"
                                   Foreground="{DynamicResource AccentForegroundBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Spacing="3" VerticalAlignment="Center">
                        <TextBlock Classes="eyebrow" Text="REVA ASSISTANT" />
                        <TextBlock Classes="heading"
                                   FontSize="{DynamicResource FontSizeSubheading}"
                                   Text="Copilot" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="2"
                        Classes="chip"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Border Classes="statusDot"
                                Background="{Binding IsOnline, Converter={x:Static conv:OnlineBrushConverter.Instance}}" />
                        <TextBlock Classes="caption"
                                   Foreground="{DynamicResource BodyForegroundBrush}"
                                   FontWeight="SemiBold"
                                   Text="{Binding ModelStatus}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      x:Name="MessageScroll"
                      Padding="24 22"
                      LayoutUpdated="OnScrollLayoutUpdated"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="18">

                <StackPanel Spacing="22" IsVisible="{Binding !HasMessages}">

                    <StackPanel Spacing="14">
                        <Border Classes="iconChip" HorizontalAlignment="Left">
                            <TextBlock Text="✦"
                                       FontSize="17"
                                       Foreground="{DynamicResource AccentBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Spacing="8">
                            <TextBlock Classes="eyebrow" Text="GET STARTED" />
                            <TextBlock Classes="display"
                                       FontSize="{DynamicResource FontSizeHeading}"
                                       LineHeight="30"
                                       Text="How can I help today?" />
                            <TextBlock Classes="muted"
                                       MaxWidth="460"
                                       HorizontalAlignment="Left"
                                       LineHeight="21"
                                       Text="{Binding Description}" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="10">
                        <TextBlock Classes="eyebrow" Text="TRY ASKING" />
                        <ItemsControl ItemsSource="{Binding Suggestions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="10" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Button Classes="suggestion"
                                            Command="{Binding $parent[ItemsControl].((vm:CopilotViewModel)DataContext).UseSuggestionCommand}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <TextBlock Text="✦"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding}"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                </StackPanel>

                <Border Classes="glass"
                        IsVisible="{Binding IsOffline}"
                        Padding="16 14">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Classes="statusDot"
                                Background="{DynamicResource WarningBrush}"
                                VerticalAlignment="Top"
                                Margin="0 5 0 0" />
                        <TextBlock Classes="caption"
                                   Foreground="{DynamicResource BodyForegroundBrush}"
                                   LineHeight="19"
                                   Text="{x:Static vm:CopilotViewModel.OfflineNotice}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="18" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:CopilotMessageViewModel">
                            <StackPanel Spacing="9">

                                <ItemsControl ItemsSource="{Binding Steps}" IsVisible="{Binding HasSteps}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Spacing="8" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:CopilotStepViewModel">
                                            <Border Classes="stepChip">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="11">
                                                    <Border Grid.Column="0" Classes="stepIcon">
                                                        <TextBlock Text="⚙" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Spacing="5">
                                                        <StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
                                                            <TextBlock Classes="caption"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource ForegroundBrush}"
                                                                       Text="{Binding DisplayName}"
                                                                       VerticalAlignment="Center" />
                                                            <Border Classes="statusDot"
                                                                    Background="{Binding IsComplete, Converter={x:Static conv:OnlineBrushConverter.Instance}}" />
                                                            <TextBlock Classes="caption"
                                                                       Text="{Binding StatusText}"
                                                                       VerticalAlignment="Center" />
                                                        </StackPanel>
                                                        <TextBlock Classes="caption"
                                                                   IsVisible="{Binding HasArguments}"
                                                                   Foreground="{DynamicResource BodyForegroundBrush}"
                                                                   Text="{Binding Arguments}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Classes="caption"
                                                                   IsVisible="{Binding HasResult}"
                                                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                                                   Text="{Binding Result}"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="12"
                                      IsVisible="{Binding IsThinking}">
                                    <Border Grid.Column="0" Classes="avatar">
                                        <TextBlock Text="✦" />
                                    </Border>
                                    <Border Grid.Column="1"
                                            Classes="bubble assistant"
                                            Padding="16 14"
                                            HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                                            <Ellipse Classes="thinkingDot" />
                                            <Ellipse Classes="thinkingDot" Opacity="0.55" />
                                            <Ellipse Classes="thinkingDot" Opacity="0.3" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="12"
                                      IsVisible="{Binding Text, Converter={x:Static conv:NonEmptyConverter.Instance}}">

                                    <Border Grid.Column="0"
                                            Classes="avatar"
                                            IsVisible="{Binding IsAssistant}">
                                        <TextBlock Text="✦" />
                                    </Border>

                                    <Border Grid.Column="1"
                                            Classes="bubble"
                                            Classes.user="{Binding IsUser}"
                                            Classes.assistant="{Binding IsAssistant}">
                                        <SelectableTextBlock Text="{Binding Text}"
                                                             TextWrapping="Wrap"
                                                             FontFamily="{DynamicResource AppFontFamily}"
                                                             FontSize="{DynamicResource FontSizeBody}"
                                                             LineHeight="21" />
                                    </Border>

                                </Grid>

                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                IsVisible="{Binding HasActivity}"
                Classes="glass"
                CornerRadius="0"
                BorderThickness="0 1 0 0"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                Padding="24 12">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Border Classes="statusDot" Background="{DynamicResource AccentBrush}" />
                <TextBlock Classes="caption"
                           Foreground="{DynamicResource AccentBrush}"
                           FontWeight="SemiBold"
                           Text="{Binding ActivityText}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <Border Grid.Row="3"
                Classes="glassStrong"
                CornerRadius="0"
                BorderThickness="0 1 0 0"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                Padding="24 18">
            <StackPanel Spacing="13">

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <TextBox Grid.Column="0"
                             Classes="composer"
                             Text="{Binding Input, Mode=TwoWay}"
                             PlaceholderText="Ask the copilot anything…"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalAlignment="Stretch" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Spacing="9">
                        <Button Classes="primary"
                                Content="Send"
                                IsVisible="{Binding !IsBusy}"
                                Command="{Binding SendCommand}" />
                        <Button Classes="secondary"
                                Content="Stop"
                                IsVisible="{Binding IsBusy}"
                                Command="{Binding CancelCommand}" />
                    </StackPanel>
                </Grid>

                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
                        <Border Classes="statusDot"
                                Background="{Binding IsOnline, Converter={x:Static conv:OnlineBrushConverter.Instance}}" />
                        <TextBlock Classes="caption" Text="{Binding ModelStatus}" VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Classes="ghost"
                            Content="Clear"
                            FontSize="{DynamicResource FontSizeCaption}"
                            Height="32"
                            Padding="14 0"
                            IsVisible="{Binding HasMessages}"
                            Command="{Binding ClearCommand}" />
                </Grid>

            </StackPanel>
        </Border>

    </Grid>
</UserControl>
