<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Reva.App.ViewModels"
             xmlns:conv="using:Reva.App.Converters"
             x:Class="Reva.App.Views.ExportView"
             x:DataType="vm:ExportViewModel"
             x:CompileBindings="True">

    <UserControl.Styles>
        <Style Selector="ComboBox.cell">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="12 6" />
        </Style>
        <Style Selector="TextBox.cell">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="12 7" />
        </Style>
        <Style Selector="ListBox.templates">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="ListBox.templates ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0 0 0 12" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusLg}" />
        </Style>
        <Style Selector="ListBox.templates ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.templateRow">
            <Setter Property="Background" Value="{DynamicResource GlassBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusLg}" />
            <Setter Property="Padding" Value="16 14" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="ListBox.templates ListBoxItem:pointerover Border.templateRow">
            <Setter Property="Background" Value="{DynamicResource GlassStrongBrush}" />
        </Style>
        <Style Selector="ListBox.templates ListBoxItem:selected Border.templateRow">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
            <Setter Property="BoxShadow" Value="{DynamicResource AccentGlow}" />
        </Style>
        <Style Selector="Border.previewHead">
            <Setter Property="Background" Value="{DynamicResource Surface2Brush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0 0 1 1" />
            <Setter Property="Padding" Value="16 12" />
            <Setter Property="MinWidth" Value="132" />
        </Style>
        <Style Selector="Border.previewCell">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0 0 1 1" />
            <Setter Property="Padding" Value="16 12" />
            <Setter Property="MinWidth" Value="132" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" Margin="32 28">

        <Border Grid.Row="0" Classes="hero" Margin="0 0 0 24">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="12" VerticalAlignment="Center" Margin="2 0 0 0">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Border Classes="logoChip" VerticalAlignment="Center">
                            <TextBlock Text="◰" FontSize="17" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentForegroundBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Classes="eyebrow" Text="WORKSPACE · EXPORT STUDIO"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Classes="display" Text="{Binding Title}" />
                    <TextBlock Classes="muted" Text="{Binding Description}" MaxWidth="600" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Button Classes="ghost" Content="Import template" Command="{Binding ImportTemplateFileCommand}" />
                    <Button Classes="secondary" Content="New template" Command="{Binding NewTemplateCommand}" />
                    <Button Classes="secondary" Content="Refresh" Command="{Binding LoadCommand}" IsEnabled="{Binding !IsBusy}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="360,*" ColumnSpacing="24">

            <Border Grid.Column="0" Classes="card" Padding="22">
                <Grid RowDefinitions="Auto,*,Auto,Auto">

                    <StackPanel Grid.Row="0" Spacing="4" Margin="2 0 2 18">
                        <TextBlock Classes="eyebrow" Text="TEMPLATES" />
                        <TextBlock Classes="caption"
                                   Text="{Binding TemplateCount, StringFormat='{}{0} available'}" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1">
                        <Panel>
                            <ListBox Classes="templates"
                                     ItemsSource="{Binding Templates}"
                                     SelectedItem="{Binding Selected, Mode=TwoWay}"
                                     IsVisible="{Binding HasTemplates}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:TemplateEditorViewModel">
                                        <Border Classes="templateRow">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <StackPanel Grid.Column="0" Spacing="8">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                               FontSize="{DynamicResource FontSizeSubheading}"
                                                               Foreground="{DynamicResource ForegroundBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <Border Classes="badge info">
                                                            <TextBlock Text="{Binding FormatLabel}" />
                                                        </Border>
                                                        <TextBlock Classes="caption" VerticalAlignment="Center"
                                                                   Text="{Binding StatusLabel}" />
                                                    </StackPanel>
                                                </StackPanel>
                                                <Border Grid.Column="1" Classes="badge neutral" VerticalAlignment="Center"
                                                        IsVisible="{Binding IsBuiltIn}">
                                                    <TextBlock Text="BUILT-IN" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <StackPanel IsVisible="{Binding IsTemplateListEmpty}"
                                        VerticalAlignment="Center" Spacing="14" Margin="6 28">
                                <Border Width="64" Height="64" CornerRadius="{DynamicResource CornerRadiusXl}"
                                        Background="{DynamicResource AccentSoftBrush}"
                                        BorderBrush="{DynamicResource AccentBorderBrush}"
                                        BorderThickness="1"
                                        BoxShadow="{DynamicResource AccentGlow}"
                                        HorizontalAlignment="Center">
                                    <TextBlock Text="▤" FontSize="26" Foreground="{DynamicResource AccentBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Classes="subheading" Text="No templates"
                                           HorizontalAlignment="Center" />
                                <TextBlock Classes="muted" TextAlignment="Center"
                                           Text="Create a new template or import one from a file to get started." />
                                <Button Classes="secondary" HorizontalAlignment="Center"
                                        Content="New template" Command="{Binding NewTemplateCommand}" />
                            </StackPanel>

                            <StackPanel IsVisible="{Binding IsBusy}"
                                        VerticalAlignment="Center" Spacing="12" Margin="6 28">
                                <Border Width="56" Height="56" CornerRadius="{DynamicResource CornerRadiusLg}"
                                        Background="{DynamicResource Surface2Brush}"
                                        BorderBrush="{DynamicResource GlassBorderBrush}"
                                        BorderThickness="1"
                                        HorizontalAlignment="Center">
                                    <TextBlock Text="▤" FontSize="22" Foreground="{DynamicResource MutedForegroundBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Classes="muted" HorizontalAlignment="Center"
                                           Text="Loading templates…" />
                            </StackPanel>
                        </Panel>
                    </ScrollViewer>

                    <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0 1 0 0"
                            Margin="0 18 0 0" Padding="0 18 0 0">
                        <StackPanel Spacing="12">
                            <TextBlock Classes="eyebrow" Text="EXPORT SOURCE" />
                            <ComboBox Classes="cell" HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding Documents}"
                                      SelectedItem="{Binding SelectedDocument, Mode=TwoWay}"
                                      PlaceholderText="Select a document">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:DocumentOptionViewModel">
                                        <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Classes="primary" HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Content="Export selected document"
                                    Command="{Binding ExportDocumentCommand}" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="3" Spacing="8" Margin="0 16 0 0"
                                IsVisible="{Binding StatusMessage, Converter={x:Static conv:NonEmptyConverter.Instance}}">
                        <Border Classes="badge info" HorizontalAlignment="Stretch" Padding="14 10"
                                IsVisible="{Binding !HasError}">
                            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
                        </Border>
                        <Border Classes="badge danger" HorizontalAlignment="Stretch" Padding="14 10"
                                IsVisible="{Binding HasError}">
                            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Classes="card" Padding="0">
                <Panel>
                    <Grid RowDefinitions="*" IsVisible="{Binding HasSelection}">
                        <ScrollViewer>
                            <StackPanel Spacing="24" Margin="24">

                                <Border Classes="hero" Padding="24 22">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Spacing="8" VerticalAlignment="Center">
                                            <TextBlock Classes="eyebrow" Text="TEMPLATE" />
                                            <TextBlock Classes="heading" Text="{Binding Selected.Name}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                            <Button Classes="ghost" Content="Duplicate" Command="{Binding DuplicateTemplateCommand}" />
                                            <Button Classes="ghost" Content="Export to file" Command="{Binding ExportTemplateFileCommand}" />
                                            <Button Classes="ghost" Content="Delete" Command="{Binding DeleteTemplateCommand}"
                                                    IsEnabled="{Binding CanEdit}" />
                                            <Button Classes="primary" Content="Save" Command="{Binding SaveTemplateCommand}"
                                                    IsEnabled="{Binding CanEdit}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Classes="badge warning" HorizontalAlignment="Left" Padding="14 9"
                                        IsVisible="{Binding !CanEdit}">
                                    <TextBlock Text="Built-in template — duplicate it to customize." />
                                </Border>

                                <Grid ColumnDefinitions="*,240" ColumnSpacing="18">
                                    <StackPanel Grid.Column="0" Spacing="10">
                                        <TextBlock Classes="eyebrow" Text="NAME" />
                                        <TextBox Classes="cell" Text="{Binding Selected.Name, Mode=TwoWay}"
                                                 IsEnabled="{Binding CanEdit}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="10">
                                        <TextBlock Classes="eyebrow" Text="FORMAT" />
                                        <ComboBox Classes="cell" HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding Formats}"
                                                  SelectedItem="{Binding Selected.Format, Mode=TwoWay}"
                                                  IsEnabled="{Binding CanEdit}" />
                                    </StackPanel>
                                </Grid>

                                <StackPanel Spacing="16">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Spacing="3" VerticalAlignment="Center">
                                            <TextBlock Classes="subheading" Text="Included fields" />
                                            <TextBlock Classes="caption"
                                                       Text="Map each output column to a source field." />
                                        </StackPanel>
                                        <Button Grid.Column="1" Classes="secondary" Content="Add column"
                                                Command="{Binding AddColumnCommand}" IsEnabled="{Binding CanEdit}" />
                                    </Grid>

                                    <Border Classes="panel" Padding="0" ClipToBounds="True"
                                            IsVisible="{Binding Selected.HasColumns}">
                                        <StackPanel>
                                            <Grid ColumnDefinitions="*,*,Auto" Background="{DynamicResource Surface2Brush}">
                                                <TextBlock Grid.Column="0" Classes="eyebrow" Text="OUTPUT HEADER"
                                                           Padding="16 14" />
                                                <TextBlock Grid.Column="1" Classes="eyebrow" Text="SOURCE FIELD"
                                                           Padding="16 14" />
                                                <TextBlock Grid.Column="2" Classes="eyebrow" Text=""
                                                           Padding="16 14" MinWidth="120" />
                                            </Grid>

                                            <ItemsControl ItemsSource="{Binding Selected.Columns}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:ColumnEditorViewModel">
                                                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="0 1 0 0">
                                                            <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="14"
                                                                  Margin="16 12">
                                                                <TextBox Grid.Column="0" Classes="cell"
                                                                         Text="{Binding Header, Mode=TwoWay}"
                                                                         PlaceholderText="Output column name"
                                                                         IsEnabled="{Binding IsEditable}" />
                                                                <ComboBox Grid.Column="1" Classes="cell" HorizontalAlignment="Stretch"
                                                                          ItemsSource="{Binding Sources}"
                                                                          SelectedItem="{Binding Source, Mode=TwoWay}"
                                                                          IsEnabled="{Binding IsEditable}" />
                                                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2"
                                                                            VerticalAlignment="Center"
                                                                            IsVisible="{Binding IsEditable}">
                                                                    <Button Classes="icon" Content="↑"
                                                                            Command="{Binding MoveUpCommand}" />
                                                                    <Button Classes="icon" Content="↓"
                                                                            Command="{Binding MoveDownCommand}" />
                                                                    <Button Classes="icon" Content="✕"
                                                                            Foreground="{DynamicResource DangerBrush}"
                                                                            Command="{Binding RemoveCommand}" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <Border Classes="panel" Background="{DynamicResource Surface2Brush}"
                                            Padding="20 18" IsVisible="{Binding !Selected.HasColumns}">
                                        <TextBlock Classes="muted" TextAlignment="Center"
                                                   Text="No columns yet. Add a column to map an output header to a source field." />
                                    </Border>
                                </StackPanel>

                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0 1 0 0" Padding="0 22 0 0">
                                    <StackPanel Spacing="16">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="3" VerticalAlignment="Center">
                                                <TextBlock Classes="subheading" Text="Live preview" />
                                                <TextBlock Classes="caption"
                                                           Text="Rendered from the selected document and this template." />
                                            </StackPanel>
                                            <Button Grid.Column="1" Classes="secondary" Content="Refresh preview"
                                                    Command="{Binding PreviewCommand}" />
                                        </Grid>

                                        <Border Classes="panel" Padding="0" ClipToBounds="True"
                                                IsVisible="{Binding HasPreview}">
                                            <ScrollViewer HorizontalScrollBarVisibility="Auto">
                                                <StackPanel>
                                                    <ItemsControl ItemsSource="{Binding PreviewHeaders}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal" />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="x:String">
                                                                <Border Classes="previewHead">
                                                                    <TextBlock Classes="eyebrow" Text="{Binding}" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <ItemsControl ItemsSource="{Binding PreviewRows}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:PreviewRowViewModel">
                                                                <ItemsControl ItemsSource="{Binding Cells}">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <StackPanel Orientation="Horizontal" />
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate x:DataType="x:String">
                                                                            <Border Classes="previewCell">
                                                                                <TextBlock Text="{Binding}"
                                                                                           Foreground="{DynamicResource BodyForegroundBrush}"
                                                                                           TextTrimming="CharacterEllipsis" />
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </ScrollViewer>
                                        </Border>

                                        <Border Classes="panel" Background="{DynamicResource Surface2Brush}"
                                                Padding="28" IsVisible="{Binding !HasPreview}">
                                            <StackPanel Spacing="6" HorizontalAlignment="Center">
                                                <TextBlock Classes="muted" HorizontalAlignment="Center" TextAlignment="Center"
                                                           Text="Pick a source document and refresh the preview to see the rendered output." />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <StackPanel IsVisible="{Binding !HasSelection}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="18"
                                MaxWidth="400">
                        <Border Width="72" Height="72" CornerRadius="{DynamicResource CornerRadiusXl}"
                                Background="{DynamicResource AccentSoftBrush}"
                                BorderBrush="{DynamicResource AccentBorderBrush}"
                                BorderThickness="1"
                                BoxShadow="{DynamicResource AccentGlow}"
                                HorizontalAlignment="Center">
                            <TextBlock Text="◰" FontSize="30" Foreground="{DynamicResource AccentBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Classes="heading" Text="Select a template"
                                   HorizontalAlignment="Center" TextAlignment="Center" />
                        <TextBlock Classes="muted"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Text="Choose a template from the list to edit its columns, format, and preview the export." />
                    </StackPanel>
                </Panel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
