<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Reva.App.ViewModels"
             xmlns:conv="using:Reva.App.Converters"
             x:Class="Reva.App.Views.MappingsView"
             x:DataType="vm:MappingsViewModel"
             x:CompileBindings="True">

    <UserControl.Styles>
        <Style Selector="DataGrid.reva">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Surface3Brush}" />
            <Setter Property="RowBackground" Value="Transparent" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserReorderColumns" Value="False" />
            <Setter Property="CanUserResizeColumns" Value="True" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="RowHeight" Value="64" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
        </Style>
        <Style Selector="DataGrid.reva DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource Surface2Brush}" />
            <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeEyebrow}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LetterSpacing" Value="1.2" />
            <Setter Property="Padding" Value="18 14" />
            <Setter Property="SeparatorBrush" Value="Transparent" />
        </Style>
        <Style Selector="DataGrid.reva DataGridCell">
            <Setter Property="Padding" Value="18 0" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
        </Style>
        <Style Selector="DataGrid.reva DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="{DynamicResource Surface2Brush}" />
            <Setter Property="Opacity" Value="0.55" />
        </Style>
        <Style Selector="ComboBox.cell">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="12 6" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
            <Setter Property="Background" Value="{DynamicResource Surface2Brush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="CornerRadius" Value="{DynamicResource CornerRadiusMd}" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" Margin="32 28">

        <StackPanel Grid.Row="0" Spacing="20" Margin="0 0 0 22">

            <Border Classes="glass" Padding="22 18">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Classes="eyebrow" Text="WORKSPACE" />
                        <TextBlock Classes="pageTitle" Text="{Binding Title}" />
                        <TextBlock Classes="muted" Text="{Binding Description}" MaxWidth="560" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <ComboBox Classes="cell"
                                  MinWidth="190"
                                  ItemsSource="{Binding SenderFilters}"
                                  SelectedItem="{Binding SenderFilter, Mode=TwoWay}"
                                  IsEnabled="{Binding HasMappings}" />
                        <Button Classes="secondary"
                                Content="Refresh"
                                Command="{Binding RefreshCommand}"
                                IsEnabled="{Binding !IsBusy}" />
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="14">
                <Border Classes="kpi" MinWidth="168">
                    <StackPanel Spacing="10">
                        <Border Classes="iconChip" HorizontalAlignment="Left">
                            <TextBlock Text="⇄" FontSize="16"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{DynamicResource AccentBrush}" />
                        </Border>
                        <TextBlock Classes="eyebrow" Text="LEARNED MAPPINGS" />
                        <TextBlock Classes="kpiValue" Text="{Binding MappingCount}" />
                        <TextBlock Classes="caption" Text="source headers resolved" />
                    </StackPanel>
                </Border>
                <Border Classes="kpi" MinWidth="168">
                    <StackPanel Spacing="10">
                        <Border Classes="iconChip" HorizontalAlignment="Left">
                            <TextBlock Text="◧" FontSize="16"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{DynamicResource AccentBrush}" />
                        </Border>
                        <TextBlock Classes="eyebrow" Text="SENDERS" />
                        <TextBlock Classes="kpiValue" Text="{Binding SenderCount}" />
                        <TextBlock Classes="caption" Text="distinct counterparties" />
                    </StackPanel>
                </Border>
                <Border Classes="badge danger"
                        VerticalAlignment="Center"
                        Padding="14 8"
                        IsVisible="{Binding HasError}">
                    <TextBlock Text="{Binding StatusMessage}" />
                </Border>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Classes="card" Padding="0" ClipToBounds="True">
            <Panel>

                <DataGrid Classes="reva"
                          ItemsSource="{Binding Mappings}"
                          IsVisible="{Binding HasMappings}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="SENDER" Width="1.2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="vm:MappingRowViewModel">
                                    <StackPanel Spacing="3" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Sender}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Classes="caption" Text="{Binding DocumentCount, StringFormat='{}{0} document(s)'}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="SOURCE HEADER" Width="1.4*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="vm:MappingRowViewModel">
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SourceHeader}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource BodyForegroundBrush}"
                                                   FontFamily="{DynamicResource AppFontFamily}" />
                                        <TextBlock Text="→"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource MutedForegroundBrush}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="CANONICAL FIELD" Width="1.4*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="vm:MappingRowViewModel">
                                    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                        <ComboBox Grid.Column="0"
                                                  Classes="cell"
                                                  HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding CanonicalFields}"
                                                  SelectedItem="{Binding CanonicalField, Mode=TwoWay}" />
                                        <Border Grid.Column="1"
                                                Classes="statusDot"
                                                Margin="10 0 0 0"
                                                Background="{DynamicResource WarningBrush}"
                                                IsVisible="{Binding IsSaving}" />
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="CONFIDENCE" Width="1.1*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="vm:MappingRowViewModel">
                                    <StackPanel Spacing="7" VerticalAlignment="Center">
                                        <TextBlock Classes="caption"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BodyForegroundBrush}"
                                                   Text="{Binding ConfidenceDisplay}" />
                                        <Border Width="120" Height="6" CornerRadius="3"
                                                HorizontalAlignment="Left"
                                                Background="{DynamicResource Surface3Brush}">
                                            <Border Height="6"
                                                    CornerRadius="3"
                                                    HorizontalAlignment="Left"
                                                    Background="{DynamicResource AccentBrush}"
                                                    Width="{Binding ConfidencePercent}" />
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="ORIGIN" Width="0.9*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="vm:MappingRowViewModel">
                                    <StackPanel VerticalAlignment="Center" Spacing="5">
                                        <Border Classes="badge info" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding OriginLabel}" />
                                        </Border>
                                        <TextBlock Classes="caption"
                                                   Foreground="{DynamicResource DangerBrush}"
                                                   Text="{Binding SaveError}"
                                                   IsVisible="{Binding SaveError, Converter={x:Static conv:NonEmptyConverter.Instance}}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel IsVisible="{Binding IsEmpty}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="14"
                            MaxWidth="380">
                    <Border Width="64" Height="64" CornerRadius="{DynamicResource CornerRadiusLg}"
                            Background="{DynamicResource AccentSoftBrush}"
                            HorizontalAlignment="Center">
                        <TextBlock Text="⇄" FontSize="28" Foreground="{DynamicResource AccentBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Classes="subheading" Text="No mappings learned yet"
                               HorizontalAlignment="Center" TextAlignment="Center" />
                    <TextBlock Classes="muted"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Text="As you review documents, Reva learns how each sender's headers map to canonical reinsurance fields. They will appear here, ready to override." />
                    <Button Classes="secondary"
                            HorizontalAlignment="Center"
                            Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            IsEnabled="{Binding !IsBusy}" />
                </StackPanel>

                <Border IsVisible="{Binding IsBusy}"
                        Background="{DynamicResource GlassStrongBrush}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14">
                        <Border Width="56" Height="56" CornerRadius="{DynamicResource CornerRadiusLg}"
                                Background="{DynamicResource AccentSoftBrush}"
                                HorizontalAlignment="Center">
                            <TextBlock Text="⇄" FontSize="24" Foreground="{DynamicResource AccentBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Classes="subheading" Text="Loading mappings…" HorizontalAlignment="Center" />
                        <TextBlock Classes="muted" Text="Aggregating learned headers across documents."
                                   HorizontalAlignment="Center" TextAlignment="Center" />
                    </StackPanel>
                </Border>

            </Panel>
        </Border>
    </Grid>
</UserControl>
