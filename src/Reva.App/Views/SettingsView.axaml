<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Reva.App.ViewModels"
             xmlns:conv="using:Reva.App.Converters"
             x:Class="Reva.App.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             x:CompileBindings="True">

    <Grid>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="22" Margin="36 32" MaxWidth="1080" HorizontalAlignment="Left">

                <Border Classes="hero">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Classes="eyebrow" Text="WORKSPACE" />
                            <TextBlock Classes="pageTitle" Text="{Binding Title}" />
                            <TextBlock Classes="muted" Text="{Binding Description}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Top">
                            <Button Classes="ghost"
                                    Content="Refresh"
                                    Command="{Binding RefreshCommand}"
                                    IsEnabled="{Binding !IsBusy}" />
                            <Button Classes="primary"
                                    Content="Save changes"
                                    Command="{Binding SaveCommand}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Classes="glass"
                        Padding="18 16"
                        IsVisible="{Binding HasStatusMessage}">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0"
                                Classes="statusDot"
                                Background="{DynamicResource AccentBrush}"
                                Margin="2 0 12 0" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding StatusMessage}"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="2"
                                Classes="icon"
                                Content="✕"
                                Foreground="{DynamicResource MutedForegroundBrush}"
                                Command="{Binding DismissStatusCommand}" />
                    </Grid>
                </Border>

                <Border Classes="card">
                    <StackPanel Spacing="20">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0" Classes="iconChip" Width="44" Height="44" VerticalAlignment="Top">
                                <TextBlock Text="AI"
                                           FontWeight="Bold"
                                           FontSize="{DynamicResource FontSizeCaption}"
                                           Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="6" Margin="16 0 0 0">
                                <TextBlock Classes="eyebrow" Text="AI MODEL" />
                                <TextBlock Classes="subheading" Text="Extraction model" />
                                <TextBlock Classes="muted"
                                           Text="Choose the local vision-language model Reva uses to read scanned and image-based documents." />
                            </StackPanel>
                            <Border Grid.Column="2" Classes="chip" VerticalAlignment="Top">
                                <StackPanel Orientation="Horizontal" Spacing="9">
                                    <Border Classes="statusDot"
                                            Background="{Binding IsOllamaOnline, Converter={x:Static conv:OnlineBrushConverter.Instance}}" />
                                    <TextBlock Text="{Binding OllamaStatusText}" Classes="caption" VerticalAlignment="Center" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource BorderBrush}" />

                        <StackPanel Spacing="10">
                            <TextBlock Classes="eyebrow" Text="ACTIVE MODEL" />

                            <ComboBox ItemsSource="{Binding Models}"
                                      SelectedItem="{Binding SelectedModel, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"
                                      MinHeight="46"
                                      IsVisible="{Binding HasModels}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ModelOption">
                                        <Grid ColumnDefinitions="*,Auto" Margin="2 4">
                                            <StackPanel Grid.Column="0" Spacing="3">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                    <Border Classes="badge neutral" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Kind}" />
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Notes}"
                                                           Classes="caption"
                                                           IsVisible="{Binding HasNotes}" />
                                            </StackPanel>
                                            <Border Grid.Column="1"
                                                    Classes="badge"
                                                    Classes.success="{Binding Installed}"
                                                    Classes.neutral="{Binding !Installed}"
                                                    VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="7">
                                                    <Border Classes="statusDot"
                                                            Background="{Binding Installed, Converter={x:Static conv:OnlineBrushConverter.Instance}}" />
                                                    <TextBlock Text="{Binding InstalledLabel}"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <Border Classes="chip"
                                    Padding="16 12"
                                    HorizontalAlignment="Stretch"
                                    IsVisible="{Binding HasNoModels}">
                                <TextBlock Text="{Binding NoModelsNote}"
                                           Classes="caption"
                                           VerticalAlignment="Center" />
                            </Border>

                            <TextBlock Text="{Binding DeterministicAlwaysOnNote}" Classes="caption" />
                        </StackPanel>

                        <Border Classes="chip" Padding="18 14">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="3">
                                    <TextBlock Text="Use vision extraction" Classes="subheading" />
                                    <TextBlock Text="{Binding VisionNote}" Classes="caption" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding UseVisionExtraction, Mode=TwoWay}"
                                              IsEnabled="{Binding IsVisionToggleEnabled}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Classes="card">
                    <StackPanel Spacing="18">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="eyebrow" Text="APPEARANCE" />
                            <TextBlock Classes="subheading" Text="Theme and branding" />
                            <TextBlock Classes="muted" Text="Control the workspace theme and the product name shown across the app." />
                        </StackPanel>

                        <Border Height="1" Background="{DynamicResource BorderBrush}" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="24">
                            <StackPanel Grid.Column="0" Spacing="10">
                                <TextBlock Classes="eyebrow" Text="THEME" />
                                <ComboBox ItemsSource="{Binding Themes}"
                                          SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch"
                                          MinHeight="40">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ThemeOption">
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Text="{Binding ThemeNote}" Classes="caption" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="10">
                                <TextBlock Classes="eyebrow" Text="PRODUCT NAME" />
                                <TextBox Text="{Binding ProductName, Mode=TwoWay}"
                                         PlaceholderText="Reve Intelligence"
                                         MinHeight="40" />
                                <TextBlock Text="Shown across the app. Leave blank to use the default."
                                           Classes="caption" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Classes="card">
                    <StackPanel Spacing="18">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="eyebrow" Text="PROCESSING" />
                            <TextBlock Classes="subheading" Text="Reconciliation and confidence" />
                            <TextBlock Classes="muted" Text="Tune how strictly Reva flags totals and how it tiers extraction confidence." />
                        </StackPanel>

                        <Border Height="1" Background="{DynamicResource BorderBrush}" />

                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Classes="subheading" Text="Reconciliation tolerance" />
                                <Border Grid.Column="1" Classes="badge info" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ReconciliationToleranceLabel}" />
                                </Border>
                            </Grid>
                            <TextBlock Classes="caption"
                                       Text="A stated total within this fraction of the computed total is treated as agreeing." />
                            <Slider Minimum="0" Maximum="0.1" SmallChange="0.001" LargeChange="0.01"
                                    Value="{Binding ReconciliationTolerance, Mode=TwoWay}"
                                    Foreground="{DynamicResource AccentBrush}" />
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="24">
                            <StackPanel Grid.Column="0" Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Classes="subheading" Text="Low threshold" />
                                    <Border Grid.Column="1" Classes="badge warning" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ConfidenceLowLabel}" />
                                    </Border>
                                </Grid>
                                <TextBlock Classes="caption" Text="Scores below this render as Low." />
                                <Slider Minimum="0" Maximum="1" SmallChange="0.01" LargeChange="0.05"
                                        Value="{Binding ConfidenceLowMax, Mode=TwoWay}"
                                        Foreground="{DynamicResource WarningBrush}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Classes="subheading" Text="Medium threshold" />
                                    <Border Grid.Column="1" Classes="badge success" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ConfidenceMediumLabel}" />
                                    </Border>
                                </Grid>
                                <TextBlock Classes="caption" Text="At or above this renders as High." />
                                <Slider Minimum="0" Maximum="1" SmallChange="0.01" LargeChange="0.05"
                                        Value="{Binding ConfidenceMediumMax, Mode=TwoWay}"
                                        Foreground="{DynamicResource SuccessBrush}" />
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource BorderBrush}" />

                        <Border Classes="chip" Padding="18 14">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="3">
                                    <TextBlock Text="Docling OCR conversion" Classes="subheading" />
                                    <TextBlock Text="{Binding DoclingNote}"
                                               Classes="caption" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding EnableDocling, Mode=TwoWay}" />
                            </Grid>
                        </Border>

                        <StackPanel Spacing="10">
                            <TextBlock Classes="eyebrow" Text="DEFAULT EXPORT TEMPLATE" />
                            <ComboBox ItemsSource="{Binding Templates}"
                                      SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"
                                      MinHeight="40">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:TemplateOption">
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Text="Preselected when you open the export view."
                                       Classes="caption" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Classes="card" BorderBrush="{DynamicResource DangerBrush}">
                    <StackPanel Spacing="18">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="eyebrow" Text="DATA" Foreground="{DynamicResource DangerBrush}" />
                            <TextBlock Classes="subheading" Text="Data maintenance" Foreground="{DynamicResource DangerBrush}" />
                            <TextBlock Classes="muted" Text="Reset the workspace to demo data or remove everything. These actions are irreversible." />
                        </StackPanel>

                        <Border Height="1" Background="{DynamicResource BorderBrush}" />

                        <TextBlock Text="{Binding MaintenanceNote}" Classes="caption" />

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button Classes="secondary"
                                    Content="Reseed demo data"
                                    Command="{Binding RequestReseedCommand}" />
                            <Button Classes="secondary"
                                    Content="Clear workspace"
                                    Foreground="{DynamicResource DangerBrush}"
                                    BorderBrush="{DynamicResource DangerBrush}"
                                    Command="{Binding RequestClearWorkspaceCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Border IsVisible="{Binding IsConfirmOpen}"
                Classes="scrim"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Border Classes="glassStrong"
                    Width="440"
                    Padding="{DynamicResource SpacingCard}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Spacing="16">
                    <TextBlock Classes="subheading" Text="{Binding ConfirmTitle}" />
                    <TextBlock Classes="muted" Text="{Binding ConfirmMessage}" />
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                        <Button Classes="secondary" Content="Cancel" Command="{Binding CancelConfirmCommand}" />
                        <Button Classes="primary"
                                Content="{Binding ConfirmActionLabel}"
                                Command="{Binding AcknowledgeConfirmCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
