<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Reva.App.ViewModels"
             xmlns:nav="using:Reva.App.Navigation"
             xmlns:conv="using:Reva.App.Converters"
             xmlns:views="using:Reva.App.Views"
             xmlns:onb="using:Reva.App.Onboarding"
             x:Class="Reva.App.Views.ShellView"
             x:DataType="vm:ShellViewModel"
             x:CompileBindings="True">

    <UserControl.Resources>
        <conv:StringEqualsConverter x:Key="RouteActive" />
    </UserControl.Resources>

    <Grid Background="{DynamicResource BgBrush}">
        <Grid ColumnDefinitions="Auto,*,Auto">

            <Border Grid.Column="0"
                    Width="252"
                    Margin="18 18 0 18"
                    Classes="glass"
                    CornerRadius="{DynamicResource CornerRadiusXl}">
                <Grid RowDefinitions="Auto,*,Auto" Margin="16 20">

                    <StackPanel Grid.Row="0" Margin="6 0 6 24" Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Width="38" Height="38"
                                    CornerRadius="{DynamicResource CornerRadiusMd}"
                                    ClipToBounds="True"
                                    Background="{DynamicResource AccentGradientBrush}"
                                    BoxShadow="{DynamicResource AccentGlow}">
                                <Image Source="/Assets/reva-icon.png" Stretch="UniformToFill" />
                            </Border>
                            <StackPanel VerticalAlignment="Center" Spacing="0">
                                <TextBlock Text="{Binding AppTitle}" Classes="subheading" FontSize="18" />
                                <TextBlock Text="Programmer Analyst" Classes="caption" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Spacing="0">
                        <TextBlock Text="WORKSPACE" Classes="eyebrow" Margin="12 0 0 12" />

                        <Button Name="TourTargetNavDashboard"
                                Classes="nav"
                                Classes.active="{Binding ActiveRoute, Converter={StaticResource RouteActive}, ConverterParameter={x:Static nav:AppRoutes.Dashboard}}"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="{x:Static nav:AppRoutes.Dashboard}">
                            <StackPanel Orientation="Horizontal" Spacing="13">
                                <TextBlock Text="▤" FontSize="16" VerticalAlignment="Center" />
                                <TextBlock Text="Dashboard" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Name="TourTargetNavReview"
                                Classes="nav"
                                Classes.active="{Binding ActiveRoute, Converter={StaticResource RouteActive}, ConverterParameter={x:Static nav:AppRoutes.Review}}"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="{x:Static nav:AppRoutes.Review}">
                            <StackPanel Orientation="Horizontal" Spacing="13">
                                <TextBlock Text="✓" FontSize="16" VerticalAlignment="Center" />
                                <TextBlock Text="Review" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Name="TourTargetNavMappings"
                                Classes="nav"
                                Classes.active="{Binding ActiveRoute, Converter={StaticResource RouteActive}, ConverterParameter={x:Static nav:AppRoutes.Mappings}}"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="{x:Static nav:AppRoutes.Mappings}">
                            <StackPanel Orientation="Horizontal" Spacing="13">
                                <TextBlock Text="⇄" FontSize="16" VerticalAlignment="Center" />
                                <TextBlock Text="Mappings" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Name="TourTargetNavExport"
                                Classes="nav"
                                Classes.active="{Binding ActiveRoute, Converter={StaticResource RouteActive}, ConverterParameter={x:Static nav:AppRoutes.Export}}"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="{x:Static nav:AppRoutes.Export}">
                            <StackPanel Orientation="Horizontal" Spacing="13">
                                <TextBlock Text="↧" FontSize="16" VerticalAlignment="Center" />
                                <TextBlock Text="Export" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Name="TourTargetNavSettings"
                                Classes="nav"
                                Classes.active="{Binding ActiveRoute, Converter={StaticResource RouteActive}, ConverterParameter={x:Static nav:AppRoutes.Settings}}"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="{x:Static nav:AppRoutes.Settings}">
                            <StackPanel Orientation="Horizontal" Spacing="13">
                                <TextBlock Text="⚙" FontSize="16" VerticalAlignment="Center" />
                                <TextBlock Text="Settings" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Border Grid.Row="2" Classes="chip" Margin="2 18 2 0" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="9">
                            <Border Classes="statusDot"
                                    Background="{Binding IsOnline, Converter={x:Static conv:OnlineBrushConverter.Instance}}" />
                            <TextBlock Text="{Binding StatusText}" Classes="caption" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1" RowDefinitions="Auto,*" Margin="18 18 18 18">

                <Border Grid.Row="0"
                        Classes="glass"
                        CornerRadius="{DynamicResource CornerRadiusLg}"
                        Padding="22 0"
                        Height="66"
                        Margin="0 0 0 18"
                        ZIndex="1">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="WORKSPACE" Classes="eyebrow" />
                            <TextBlock Text="Programmer Analyst" Classes="subheading" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
                            <Button Classes="icon"
                                    Padding="0"
                                    CornerRadius="{DynamicResource CornerRadiusPill}"
                                    Command="{Binding RefreshModelStatusCommand}"
                                    ToolTip.Tip="{Binding StatusText}"
                                    IsVisible="{Binding ActiveModel, Converter={x:Static conv:NonEmptyConverter.Instance}}">
                                <Border Classes="chip">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Classes="statusDot"
                                                Background="{Binding IsOnline, Converter={x:Static conv:OnlineBrushConverter.Instance}}" />
                                        <TextBlock Text="{Binding ActiveModel}" Classes="caption" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Button>
                            <Button Name="TourTargetTourButton"
                                    Classes="ghost"
                                    Click="OnStartTourClicked"
                                    Content="Tour" />
                            <Button Classes="icon" Command="{Binding ToggleThemeCommand}" Content="◐" FontSize="16" />
                            <Button Classes="primary" Command="{Binding ToggleCopilotCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="✦" FontSize="13" VerticalAlignment="Center"
                                               Foreground="{DynamicResource AccentForegroundBrush}" />
                                    <TextBlock Text="Copilot" VerticalAlignment="Center"
                                               Foreground="{DynamicResource AccentForegroundBrush}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <ContentControl Name="TourTargetContentHost" Grid.Row="1" Content="{Binding Current}"
                                Background="Transparent" />
            </Grid>

            <Border Name="TourTargetCopilotDock"
                    Grid.Column="2"
                    Width="392"
                    Margin="0 18 18 18"
                    IsVisible="{Binding IsCopilotOpen}"
                    Classes="glass"
                    CornerRadius="{DynamicResource CornerRadiusXl}">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="0 0 0 1"
                            Padding="20 0" Height="66">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0" Classes="iconChip" VerticalAlignment="Center">
                                <TextBlock Text="✦" FontSize="15" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource AccentBrush}" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12 0 0 0" Spacing="0" VerticalAlignment="Center">
                                <TextBlock Text="Copilot" Classes="subheading" />
                                <TextBlock Text="Always-on assistant" Classes="caption" />
                            </StackPanel>
                            <Button Grid.Column="2" Classes="icon" Command="{Binding ToggleCopilotCommand}"
                                    Content="✕" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ContentControl Grid.Row="1" Content="{Binding Copilot}" />
                </Grid>
            </Border>

        </Grid>

        <onb:TourOverlay />
    </Grid>
</UserControl>
