<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Reva.App.ViewModels"
             xmlns:views="using:Reva.App.Views"
             x:Class="Reva.App.Views.UploadControl"
             x:DataType="vm:UploadViewModel"
             x:CompileBindings="True"
             DragDrop.AllowDrop="True">

    <UserControl.Resources>
        <views:UploadStatusBrushConverter x:Key="StatusBrush" />
        <views:UploadProgressVisibleConverter x:Key="ProgressVisible" />
    </UserControl.Resources>

    <DockPanel LastChildFill="True">

        <Panel DockPanel.Dock="Top">

            <Border CornerRadius="{DynamicResource CornerRadiusXl}"
                    BorderThickness="1.5"
                    BorderBrush="{DynamicResource AccentBorderBrush}"
                    Background="{DynamicResource HeroWashBrush}"
                    BoxShadow="{DynamicResource AccentGlow}"
                    MinHeight="172">

                <Grid ColumnDefinitions="Auto,*,Auto"
                      VerticalAlignment="Center"
                      Margin="26 24">

                    <Border Grid.Column="0"
                            Width="58" Height="58"
                            CornerRadius="{DynamicResource CornerRadiusLg}"
                            Background="{DynamicResource GlassStrongBrush}"
                            BorderBrush="{DynamicResource GlassBorderBrush}"
                            BorderThickness="1"
                            BoxShadow="{DynamicResource ShadowGlass}"
                            Margin="0 0 20 0">
                        <TextBlock Text="&#x2191;"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AccentBrush}" />
                    </Border>

                    <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="Drop documents to ingest"
                                   Classes="heading" />
                        <TextBlock Text="Drag files anywhere here, or browse your machine."
                                   Classes="muted" />
                        <Border Classes="chip"
                                HorizontalAlignment="Left"
                                Margin="0 4 0 0"
                                Background="{DynamicResource GlassStrongBrush}">
                            <TextBlock Text="PDF &#x00B7; DOCX &#x00B7; XLSX &#x00B7; CSV &#x00B7; EML &#x00B7; PNG"
                                       Classes="caption"
                                       Foreground="{DynamicResource BodyForegroundBrush}" />
                        </Border>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Classes="primary"
                            VerticalAlignment="Center"
                            Margin="20 0 0 0"
                            IsEnabled="{Binding !IsUploading}"
                            Click="OnBrowseClicked"
                            Content="Browse files" />

                </Grid>
            </Border>

            <Border CornerRadius="{DynamicResource CornerRadiusXl}"
                    BorderThickness="1.5"
                    BorderBrush="{DynamicResource AccentBrush}"
                    Background="{DynamicResource AccentSoftBrush}"
                    BoxShadow="{DynamicResource AccentGlow}"
                    IsVisible="{Binding IsDragOver}"
                    IsHitTestVisible="False">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8">
                    <TextBlock Text="&#x2193;"
                               FontSize="30"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource AccentBrush}" />
                    <TextBlock Text="Release to upload"
                               Classes="subheading"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource AccentBrush}" />
                </StackPanel>
            </Border>

        </Panel>

        <Grid DockPanel.Dock="Bottom"
              RowDefinitions="Auto,*,Auto"
              Margin="0 18 0 0"
              IsVisible="{Binding HasEntries}">

            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="2 0 2 12">
                <TextBlock Grid.Column="0"
                           Classes="eyebrow"
                           VerticalAlignment="Center"
                           Text="UPLOAD QUEUE" />
                <Border Grid.Column="1" Classes="badge info">
                    <TextBlock Text="In progress" />
                </Border>
            </Grid>

            <ScrollViewer Grid.Row="1" MaxHeight="260" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Entries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:UploadFileEntry">
                            <Border Classes="panel"
                                    Margin="0 0 0 8"
                                    Padding="16 12"
                                    Background="{DynamicResource GlassBrush}">
                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      RowDefinitions="Auto,Auto">

                                    <Border Grid.Column="0"
                                            Grid.RowSpan="2"
                                            Width="10"
                                            Height="10"
                                            CornerRadius="999"
                                            Margin="2 0 14 0"
                                            VerticalAlignment="Center"
                                            BoxShadow="{DynamicResource AccentGlow}"
                                            Background="{Binding Status, Converter={StaticResource StatusBrush}}" />

                                    <TextBlock Grid.Column="1"
                                               Grid.Row="0"
                                               Text="{Binding FileName}"
                                               FontSize="{DynamicResource FontSizeBody}"
                                               FontWeight="Medium"
                                               Foreground="{DynamicResource ForegroundBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap" />

                                    <TextBlock Grid.Column="1"
                                               Grid.Row="1"
                                               Text="{Binding StatusText}"
                                               Classes="caption"
                                               Margin="0 2 0 0"
                                               Foreground="{Binding Status, Converter={StaticResource StatusBrush}}" />

                                    <ProgressBar Grid.Column="2"
                                                 Grid.RowSpan="2"
                                                 Width="96"
                                                 Height="6"
                                                 Margin="16 0 0 0"
                                                 VerticalAlignment="Center"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding Progress}"
                                                 CornerRadius="{DynamicResource CornerRadiusPill}"
                                                 IsVisible="{Binding Status, Converter={StaticResource ProgressVisible}}"
                                                 Foreground="{DynamicResource AccentBrush}"
                                                 Background="{DynamicResource Surface3Brush}" />

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        Spacing="10"
                        HorizontalAlignment="Right"
                        Margin="0 12 0 0">

                <Button Classes="ghost"
                        Content="Cancel"
                        IsVisible="{Binding IsUploading}"
                        Command="{Binding CancelCommand}" />

                <Button Classes="secondary"
                        Content="Clear done"
                        IsVisible="{Binding !IsUploading}"
                        Command="{Binding ClearCompletedCommand}" />

            </StackPanel>

        </Grid>

    </DockPanel>

</UserControl>
