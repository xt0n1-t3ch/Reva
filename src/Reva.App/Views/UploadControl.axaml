<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Reva.App.ViewModels"
             xmlns:views="using:Reva.App.Views"
             x:Class="Reva.App.Views.UploadControl"
             x:DataType="vm:UploadViewModel"
             x:CompileBindings="True"
             DragDrop.AllowDrop="True">

    <UserControl.Resources>
        <views:UploadStatusBrushConverter x:Key="StatusBrush" />
        <views:UploadProgressVisibleConverter x:Key="ProgressVisible" />
    </UserControl.Resources>

    <DockPanel LastChildFill="True">

        <Panel DockPanel.Dock="Top">

            <Border CornerRadius="{DynamicResource CornerRadiusXl}"
                    BorderThickness="1.5"
                    BorderBrush="{DynamicResource AccentBorderBrush}"
                    Background="{DynamicResource HeroWashBrush}"
                    BoxShadow="{DynamicResource ShadowSoft}"
                    MinHeight="148">

                <Grid ColumnDefinitions="Auto,*,Auto"
                      VerticalAlignment="Center"
                      Margin="22 18">

                    <Border Grid.Column="0"
                            Width="46" Height="46"
                            CornerRadius="{DynamicResource CornerRadiusMd}"
                            Background="{DynamicResource GlassStrongBrush}"
                            BorderBrush="{DynamicResource AccentBorderBrush}"
                            BorderThickness="1"
                            BoxShadow="{DynamicResource ShadowSoft}"
                            Margin="0 0 16 0">
                        <TextBlock Text="↑"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AccentBrush}" />
                    </Border>

                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="Drop documents to ingest"
                                   Classes="subheading" />
                        <TextBlock Text="PDF · DOCX · XLSX · CSV · EML · PNG and more"
                                   Classes="caption" />
                    </StackPanel>

                    <Button Grid.Column="2"
                            Classes="accent"
                            VerticalAlignment="Center"
                            Margin="16 0 0 0"
                            IsEnabled="{Binding !IsUploading}"
                            Click="OnBrowseClicked"
                            Content="Browse" />

                </Grid>
            </Border>

            <Border CornerRadius="{DynamicResource CornerRadiusXl}"
                    BorderThickness="1.5"
                    BorderBrush="{DynamicResource AccentBrush}"
                    Background="{DynamicResource AccentSoftBrush}"
                    BoxShadow="{DynamicResource ShadowHover}"
                    IsVisible="{Binding IsDragOver}"
                    IsHitTestVisible="False">
                <TextBlock Text="Release to upload"
                           Classes="subheading"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AccentBrush}" />
            </Border>

        </Panel>

        <Grid DockPanel.Dock="Bottom"
              RowDefinitions="*,Auto"
              Margin="0 14 0 0"
              IsVisible="{Binding HasEntries}">

            <ScrollViewer Grid.Row="0" MaxHeight="240" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Entries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:UploadFileEntry">
                            <Border Classes="chip" Margin="0 3">
                                <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">

                                    <Border Grid.Column="0"
                                            Grid.RowSpan="2"
                                            Width="8"
                                            Height="8"
                                            CornerRadius="4"
                                            Margin="0 0 12 0"
                                            VerticalAlignment="Center"
                                            Background="{Binding Status, Converter={StaticResource StatusBrush}}" />

                                    <TextBlock Grid.Column="1"
                                               Grid.Row="0"
                                               Text="{Binding FileName}"
                                               FontSize="{DynamicResource FontSizeBody}"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap" />

                                    <TextBlock Grid.Column="1"
                                               Grid.Row="1"
                                               Text="{Binding StatusText}"
                                               Classes="caption"
                                               Foreground="{Binding Status, Converter={StaticResource StatusBrush}}" />

                                    <ProgressBar Grid.Column="2"
                                                 Grid.RowSpan="2"
                                                 Width="72"
                                                 Height="4"
                                                 Margin="12 0 0 0"
                                                 VerticalAlignment="Center"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding Progress}"
                                                 CornerRadius="{DynamicResource CornerRadiusPill}"
                                                 IsVisible="{Binding Status, Converter={StaticResource ProgressVisible}}"
                                                 Foreground="{DynamicResource AccentBrush}"
                                                 Background="{DynamicResource Surface3Brush}" />

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        HorizontalAlignment="Right"
                        Margin="0 8 0 0">

                <Button Classes="ghost"
                        Content="Cancel"
                        IsVisible="{Binding IsUploading}"
                        Command="{Binding CancelCommand}" />

                <Button Classes="ghost"
                        Content="Clear done"
                        IsVisible="{Binding !IsUploading}"
                        Command="{Binding ClearCompletedCommand}" />

            </StackPanel>

        </Grid>

    </DockPanel>

</UserControl>
