<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["Reva.styles.css"]" />
    @if (HasAccent)
    {
        <style>:root { --accent: @Accent !important; }</style>
    }
    <script>
        (function () {
            var t = "@Theme";
            if (t === "system") {
                t = window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
            }
            document.documentElement.setAttribute("data-theme", t);
        })();
    </script>
    <ImportMap />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>

@code {
    private static string Theme => RuntimeSettings.Current.Theme.ToString().ToLowerInvariant();

    private static string Accent => RuntimeSettings.Current.AccentColor;

    // Re-validate the hex before injecting it into a <style> (defence in depth; the store
    // already sanitizes), so nothing arbitrary can reach the page.
    private static bool HasAccent => System.Text.RegularExpressions.Regex.IsMatch(Accent, "^#[0-9a-fA-F]{6}$");
}
