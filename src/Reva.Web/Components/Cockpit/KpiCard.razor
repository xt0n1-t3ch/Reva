<div class="kpi-card">
    <span class="kpi-icon tone-@Tone">
        <Icon Name="@IconName" Size="22" />
    </span>
    <span class="kpi-meta">
        <span class="kpi-label">@Label</span>
        <span class="kpi-value">@Value</span>
        @if (!string.IsNullOrWhiteSpace(Foot))
        {
            <span class="kpi-foot">@Foot</span>
        }
    </span>
</div>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public string? Foot { get; set; }
    [Parameter] public string Tone { get; set; } = "blue";
    [Parameter] public string IconName { get; set; } = "chart";
}
