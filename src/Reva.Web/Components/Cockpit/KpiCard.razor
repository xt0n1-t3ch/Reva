<div class="kpi-card metric-card tone-@Tone">
    <span class="kpi-icon tone-@Tone">
        <Icon Name="@IconName" Size="24" />
    </span>
    <span class="kpi-meta">
        <span class="kpi-label">@Label</span>
        <span class="kpi-value">@Value</span>
        @if (!string.IsNullOrWhiteSpace(Foot))
        {
            <span class="kpi-foot">@Foot</span>
        }
    </span>
    @if (HasSpark)
    {
        <svg class="kpi-spark" viewBox="0 0 112 34" fill="none" preserveAspectRatio="none" aria-hidden="true" focusable="false">
            <path d="@SparkPath" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
    }
</div>

@code {
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public string? Foot { get; set; }
    [Parameter] public string Tone { get; set; } = "blue";
    [Parameter] public string IconName { get; set; } = "chart";

    // Optional REAL data series. When at least two points are supplied the sparkline is
    // drawn from them; otherwise no sparkline is shown (no decorative/fake trend).
    [Parameter] public IReadOnlyList<double>? Series { get; set; }

    private bool HasSpark => Series is { Count: >= 2 };

    private string SparkPath
    {
        get
        {
            var series = Series!;
            var min = series.Min();
            var max = series.Max();
            var range = max - min;
            var lastIndex = series.Count - 1;
            var segments = series.Select((value, index) =>
            {
                var x = (double)index / lastIndex * 110 + 1;
                var y = range == 0 ? 17 : 34 - (((value - min) / range * 30) + 2);
                return FormattableString.Invariant($"{(index == 0 ? "M" : "L")}{x:0.#} {y:0.#}");
            });
            return string.Join(" ", segments);
        }
    }
}
