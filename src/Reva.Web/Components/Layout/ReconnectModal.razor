<script type="module" src="@Assets["Components/Layout/ReconnectModal.razor.js"]"></script>

@* IDs and state class names below are required by Blazor's reconnect handler — do not rename. *@
<dialog id="components-reconnect-modal" data-nosnippet>
    <div class="reconnect-card">
        <div class="reconnect-brand">
            <span class="reconnect-mark">Reve</span><span class="reconnect-sub">Intelligence</span>
        </div>

        <div class="components-rejoining-animation reconnect-spinner" aria-hidden="true">
            <div></div>
            <div></div>
        </div>

        <p class="reconnect-title components-reconnect-first-attempt-visible">Reconnecting…</p>
        <p class="reconnect-msg components-reconnect-first-attempt-visible">Restoring your session — your work is safe.</p>

        <p class="reconnect-title components-reconnect-repeated-attempt-visible">Connection lost</p>
        <p class="reconnect-msg components-reconnect-repeated-attempt-visible">Retrying in <span id="components-seconds-to-next-attempt"></span> seconds…</p>

        <p class="reconnect-title components-reconnect-failed-visible">Couldn't reconnect</p>
        <p class="reconnect-msg components-reconnect-failed-visible">Your work is preserved. Retry the connection, or reload the page.</p>

        <p class="reconnect-title components-pause-visible">Session paused</p>
        <p class="reconnect-msg components-pause-visible">The server paused this session. Resume to pick up where you left off.</p>

        <p class="reconnect-title components-resume-failed-visible">Couldn't resume</p>
        <p class="reconnect-msg components-resume-failed-visible">Please resume again, or reload the page.</p>

        <div class="reconnect-actions">
            <button id="components-reconnect-button" class="reconnect-btn reconnect-btn-primary components-reconnect-failed-visible">Retry</button>
            <button id="components-resume-button" class="reconnect-btn reconnect-btn-primary components-pause-visible components-resume-failed-visible">Resume</button>
            <a class="reconnect-btn reconnect-btn-ghost components-reconnect-failed-visible components-resume-failed-visible" href=".">Reload page</a>
        </div>
    </div>
</dialog>
