@page "/"
@rendermode @(new InteractiveServerRenderMode(false))
@inject NavigationManager Nav
@inject IDocumentWorkflow Workflow

<PageTitle>@Brand.Cockpit</PageTitle>

<header class="cockpit-topbar cockpit-topbar-workbench">
    <div class="topbar-titles">
        <h1>Workspace</h1>
        <p>Import a document and Reve turns it into clean, checked, exportable data.</p>
    </div>
    <div class="topbar-tools">
        <div class="searchbox">
            <Icon Name="search" Size="18" />
            <input type="search" placeholder="Search your documents…"
                   aria-label="Search documents" @bind="_search" @bind:event="oninput" />
        </div>
        <label class="btn btn-primary upload-control">
            <Icon Name="plus" Size="18" />
            <span>@(_uploading ? "Importing…" : "Import")</span>
            <InputFile OnChange="OnUpload" disabled="@_uploading" aria-label="Import a document" />
        </label>
        <a class="icon-btn" href="/documents" aria-label="Documents">
            <Icon Name="bell" Size="20" />
            @if (_metrics.TotalExceptions > 0)
            {
                <span class="icon-badge">@Math.Min(_metrics.TotalExceptions, 99)</span>
            }
        </a>
        <span class="top-avatar" aria-label="Analyst"><Icon Name="shield" Size="18" /></span>
    </div>
</header>

<div class="cockpit-content workspace">
    @if (_toast is not null)
    {
        <div class="toast @_toast.Value.Kind" role="status">
            <Icon Name="@(_toast.Value.Kind == "ok" ? "check-circle" : "alert")" Size="18" />
            <span>@_toast.Value.Message</span>
        </div>
    }

    @if (_loading)
    {
        <section class="card"><div class="loading-pane"><span class="spinner"></span> Loading workspace…</div></section>
    }
    else if (_documents.Count == 0)
    {
        <section class="onboard-grid" aria-label="Get started">
            <div class="onboard-copy">
                <span class="eyebrow">Welcome</span>
                <h2>Turn any insurance document into clean, trusted data.</h2>
                <p>Drop in a bordereau, statement of account, slip, or loss run. Reve reads it,
                   checks every figure against the detail, and gets it ready to export — in three steps.</p>
                <ol class="onboard-steps">
                    <li><span class="step-n">1</span><div><strong>Import</strong><span>Any format — Excel, PDF, scan, email.</span></div></li>
                    <li><span class="step-n">2</span><div><strong>Review &amp; adjust</strong><span>Fix fields, resolve the flagged checks.</span></div></li>
                    <li><span class="step-n">3</span><div><strong>Export</strong><span>Send out clean data in your format.</span></div></li>
                </ol>
            </div>
            <label class="dropzone @(_uploading ? "is-busy" : null)">
                <InputFile OnChange="OnUpload" disabled="@_uploading" aria-label="Import a document" />
                <span class="dropzone-mark">
                    @if (_uploading)
                    {
                        <span class="spinner"></span>
                    }
                    else
                    {
                        <Icon Name="export" Size="28" />
                    }
                </span>
                <strong>@(_uploading ? "Reading your document…" : "Drop a document to import")</strong>
                <span class="dropzone-sub">or click to browse — no file is ever rejected</span>
            </label>
        </section>
    }
    else
    {
        <section class="stat-row" aria-label="Overview">
            <KpiCard Tone="blue" IconName="file" Label="Documents" Value="@_metrics.Total.ToString("N0")" Foot="@DocumentsFoot" />
            <KpiCard Tone="teal" IconName="shield" Label="Avg. confidence" Value="@ConfidenceValue" Foot="@ConfidenceFoot" />
            <KpiCard Tone="amber" IconName="alert" Label="Open checks" Value="@_metrics.TotalExceptions.ToString("N0")" Foot="@ExceptionsFoot" />
            <KpiCard Tone="violet" IconName="clock" Label="Pending review" Value="@_metrics.Pending.ToString("N0")" Foot="@PendingFoot" />
        </section>

        <label class="import-bar @(_uploading ? "is-busy" : null)">
            <InputFile OnChange="OnUpload" disabled="@_uploading" aria-label="Import a document" />
            <span class="import-bar-mark">
                @if (_uploading)
                {
                    <span class="spinner"></span>
                }
                else
                {
                    <Icon Name="export" Size="20" />
                }
            </span>
            <span class="import-bar-text">
                <strong>@(_uploading ? "Reading your document…" : "Drop a document to import")</strong>
                <span>Excel, PDF, scan, Word, email — anything. No file is ever rejected.</span>
            </span>
            <span class="import-bar-cta">Browse <Icon Name="arrow-right" Size="16" /></span>
        </label>

        <section class="card card-pad-0 queue-card" aria-label="Work queue">
            <div class="card-head">
                <div class="head-title">
                    <Icon Name="queue" Size="20" />
                    <h2>Work queue</h2>
                    <span class="pill tone-slate">@Filtered.Count of @_documents.Count</span>
                </div>
                <div class="head-tools seg-filter" role="group" aria-label="Filter documents">
                    <button class="seg @(_filter == QueueFilter.All ? "is-on" : null)" type="button" @onclick="@(() => SetFilter(QueueFilter.All))">All</button>
                    <button class="seg @(_filter == QueueFilter.NeedsReview ? "is-on" : null)" type="button" @onclick="@(() => SetFilter(QueueFilter.NeedsReview))">Needs review</button>
                    <button class="seg @(_filter == QueueFilter.Clean ? "is-on" : null)" type="button" @onclick="@(() => SetFilter(QueueFilter.Clean))">Clean</button>
                </div>
            </div>
            @if (Filtered.Count == 0)
            {
                <div class="empty-state compact-empty">
                    <span class="empty-ic"><Icon Name="check-circle" Size="34" /></span>
                    <h3>Nothing here</h3>
                    <p>No documents match this filter.</p>
                </div>
            }
            else
            {
                <div class="table-scroll">
                    <table class="data-table queue-table">
                        <caption class="visually-hidden">Document work queue</caption>
                        <thead>
                            <tr>
                                <th scope="col">Document</th>
                                <th scope="col">Type</th>
                                <th scope="col">Confidence</th>
                                <th scope="col">Checks</th>
                                <th scope="col">Status</th>
                                <th scope="col">Review</th>
                                <th scope="col">Updated</th>
                                <th scope="col"><span class="visually-hidden">Open</span></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var doc in Filtered)
                            {
                                <tr class="row-link" @onclick="@(() => Open(doc.Id))">
                                    <td>
                                        <div class="cell-file">
                                            <span class="file-ic"><Icon Name="file" Size="18" /></span>
                                            <span class="cell-strong">@doc.FileName</span>
                                        </div>
                                    </td>
                                    <td class="cell-sub">@CockpitFormat.DocumentTypeLabel(doc.DocumentType)</td>
                                    <td><ConfidenceBadge Value="doc.Confidence" /></td>
                                    <td><span class="pill @CockpitFormat.ExceptionTone(doc.ExceptionCount)">@doc.ExceptionCount</span></td>
                                    <td><StatusPill Status="doc.Status" /></td>
                                    <td><ReviewPill State="doc.ReviewState" /></td>
                                    <td class="cell-sub">@CockpitFormat.RelativeTime(doc.UpdatedAt, _now)</td>
                                    <td><a class="btn btn-subtle" href="@ReviewHref(doc.Id)" @onclick:stopPropagation="true">Open <Icon Name="arrow-right" Size="16" /></a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }
</div>

@code {
    private enum QueueFilter { All, NeedsReview, Clean }

    private readonly record struct Toast(string Kind, string Message);

    private List<DocumentSummary> _documents = [];
    private Metrics _metrics = Metrics.Empty;
    private string _search = string.Empty;
    private QueueFilter _filter = QueueFilter.All;
    private bool _loading = true;
    private bool _uploading;
    private Toast? _toast;
    private DateTimeOffset _now = DateTimeOffset.UtcNow;

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            _documents = [.. (await Workflow.ListAsync(CancellationToken.None)).OrderByDescending(document => document.UpdatedAt)];
            _metrics = Metrics.From(_documents);
            _now = DateTimeOffset.UtcNow;
        }
        catch (Exception ex)
        {
            _toast = new Toast("err", $"Could not load documents: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null)
        {
            return;
        }

        _uploading = true;
        _toast = null;
        StateHasChanged();
        try
        {
            await using var source = file.OpenReadStream(DocumentIntakePolicy.MaxFileBytes);
            using var buffer = new MemoryStream();
            await source.CopyToAsync(buffer);
            buffer.Position = 0;

            var result = await Workflow.IngestAsync(file.Name, file.ContentType, buffer, CancellationToken.None);
            _toast = new Toast("ok", $"{result.FileName} imported — opening review…");
            Nav.NavigateTo($"review/{result.Id}");
        }
        catch (Exception ex)
        {
            _toast = new Toast("err", $"Import failed: {ex.Message}");
            _uploading = false;
        }
    }

    private void SetFilter(QueueFilter filter) => _filter = filter;

    private void Open(Guid id) => Nav.NavigateTo($"review/{id}");

    private string ConfidenceValue => _metrics.Extracted == 0 ? "—" : CockpitFormat.Percent(_metrics.AvgConfidence);

    private string DocumentsFoot => _metrics.Extracted == 0 ? "ready" : $"{_metrics.Extracted} processed";

    private string ConfidenceFoot => _metrics.Extracted == 0 ? "no data yet" : $"across {_metrics.Extracted}";

    private string ExceptionsFoot => _metrics.TotalExceptions == 0 ? "all clear" : $"{_metrics.Flagged} flagged";

    private string PendingFoot => _metrics.Pending == 0 ? "all caught up" : $"{_metrics.Approved} approved";

    private List<DocumentSummary> Filtered
    {
        get
        {
            IEnumerable<DocumentSummary> query = _documents;

            query = _filter switch
            {
                QueueFilter.NeedsReview => query.Where(document => document.ExceptionCount > 0 || document.ReviewState == ReviewState.Pending),
                QueueFilter.Clean => query.Where(document => document.ExceptionCount == 0),
                _ => query
            };

            if (!string.IsNullOrWhiteSpace(_search))
            {
                query = query.Where(document =>
                    document.FileName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                    CockpitFormat.DocumentTypeLabel(document.DocumentType).Contains(_search, StringComparison.OrdinalIgnoreCase));
            }

            return [.. query];
        }
    }

    private static string ReviewHref(Guid id) => $"review/{id}";

    private readonly record struct Metrics(int Total, int Extracted, double AvgConfidence, int TotalExceptions, int Flagged, int Pending, int Approved)
    {
        public static Metrics Empty => new(0, 0, 0, 0, 0, 0, 0);

        public static Metrics From(IReadOnlyList<DocumentSummary> docs)
        {
            if (docs.Count == 0)
            {
                return Empty;
            }

            var extracted = docs.Where(document => document.Status == DocumentStatus.Extracted).ToList();
            return new Metrics(
                docs.Count,
                extracted.Count,
                extracted.Count > 0 ? extracted.Average(document => document.Confidence) : 0,
                docs.Sum(document => document.ExceptionCount),
                docs.Count(document => document.ExceptionCount > 0),
                docs.Count(document => document.ReviewState == ReviewState.Pending),
                docs.Count(document => document.ReviewState == ReviewState.Approved));
        }
    }
}
