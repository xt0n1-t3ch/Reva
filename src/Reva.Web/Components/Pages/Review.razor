@page "/review/{Id:guid}"
@rendermode @(new InteractiveServerRenderMode(false))
@inject NavigationManager Nav
@inject IDocumentWorkflow Workflow
@inject IExportTemplateStore Templates

<PageTitle>@(_detail is null ? "Review" : $"Review · {_detail.FileName}")</PageTitle>

<header class="cockpit-topbar cockpit-topbar-workbench review-topbar">
    <div class="topbar-titles">
        <a class="back-link" href="/"><Icon Name="arrow-left" Size="16" /> Workspace</a>
        <h1>@(_detail?.FileName ?? "Review")</h1>
        @if (_detail is not null)
        {
            <p>@CockpitFormat.DocumentTypeLabel(_detail.DocumentType) · read via @_detail.ParserProfile · updated @CockpitFormat.RelativeTime(_detail.UpdatedAt, _now)</p>
        }
    </div>
    @if (_detail is not null && CanAct)
    {
        <div class="topbar-tools review-topbar-tools">
            <details class="export-menu">
                <summary class="btn btn-ghost"><Icon Name="export" Size="16" /> Export <Icon Name="chevron-down" Size="14" /></summary>
                <div class="export-menu-panel">
                    <span class="export-menu-label">Templates</span>
                    @foreach (var template in _templates)
                    {
                        <a class="export-menu-item" href="@TemplateExportHref(template.Id)" download>
                            <span>
                                @template.Name
                                @if (template.Id == RuntimeSettings.Current.DefaultTemplateId)
                                {
                                    <span class="pill tone-green">Default</span>
                                }
                            </span>
                            <span class="pill tone-blue">@template.Format.ToString().ToUpperInvariant()</span>
                        </a>
                    }
                    <span class="export-menu-label">Quick</span>
                    <a class="export-menu-item" href="@ExportHref("raw")" download><span>Raw parsed text</span><span class="pill tone-slate">TXT</span></a>
                </div>
            </details>
            <a class="btn btn-ghost" href="@ExportHref("json")" download aria-label="Export as JSON"><Icon Name="download" Size="16" /> JSON</a>
            <a class="btn btn-ghost" href="@ExportHref("csv")" download aria-label="Export as CSV"><Icon Name="download" Size="16" /> CSV</a>
            <button class="btn btn-primary" type="button" @onclick="ApproveAsync" disabled="@(_submitting || !CanSubmit)"><Icon Name="check" Size="16" /> Approve</button>
        </div>
    }
</header>

<div class="cockpit-content review-content">
    @if (_toast is not null)
    {
        <div class="toast @_toast.Value.Kind" role="status">
            <Icon Name="@(_toast.Value.Kind == "ok" ? "check-circle" : "alert")" Size="18" />
            <span>@_toast.Value.Message</span>
        </div>
    }

    @if (_loading)
    {
        <section class="card"><div class="loading-pane"><span class="spinner"></span> Loading review…</div></section>
    }
    else if (_detail is null)
    {
        <section class="card empty-workbench">
            <div class="empty-state">
                <span class="empty-ic"><Icon Name="x-circle" Size="44" /></span>
                <h3>Document not found</h3>
                <p>It may have been removed. Head back to the workspace to pick another.</p>
                <a class="btn btn-primary" href="/"><Icon Name="arrow-left" Size="16" /> Back to workspace</a>
            </div>
        </section>
    }
    else
    {
        <nav class="stepper" aria-label="Workflow">
            <span class="step done"><span class="step-dot"><Icon Name="check" Size="14" /></span> Import</span>
            <span class="step-line"></span>
            <span class="step active"><span class="step-dot">2</span> Review &amp; adjust</span>
            <span class="step-line"></span>
            <span class="step"><span class="step-dot">3</span> Export</span>
        </nav>

        @if (!CanAct)
        {
            <section class="attention-card" role="note">
                <div class="attention-mark"><Icon Name="alert" Size="24" /></div>
                <div>
                    <strong>@AttentionTitle</strong>
                    <p>@AttentionCopy</p>
                </div>
            </section>
        }

        <section class="review-split" aria-label="Review workspace">
            <article class="card card-pad-0 review-doc-card">
                <div class="card-head">
                    <div class="head-title"><Icon Name="file" Size="20" /><h2>Document</h2></div>
                    <span class="pill tone-slate">@_detail.FileName</span>
                </div>
                <div class="review-doc-body">
                    @if (_activeField is not null)
                    {
                        <div class="cite-hint"><Icon Name="search" Size="14" /> Showing where <strong>@_activeField</strong> appears in the document</div>
                    }
                    else
                    {
                        <div class="cite-hint muted"><Icon Name="search" Size="14" /> Hover a field on the right to highlight its source here</div>
                    }
                    <div class="doc-paper">
                        <pre class="doc-text">@HighlightedBody</pre>
                        @if (_detail.Tables.FirstOrDefault(t => t.Rows.Count > 0) is { } table)
                        {
                            <table class="doc-table">
                                <thead>
                                    <tr>
                                        @foreach (var header in table.Headers)
                                        {
                                            <th>@header</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in table.Rows)
                                    {
                                        <tr>
                                            @foreach (var header in table.Headers)
                                            {
                                                var cell = row.TryGetValue(header, out var value) ? value : string.Empty;
                                                <td class="@CiteClass(cell)">@cell</td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </article>

            <div class="review-side">
                @if (ShowFields)
                {
                    <article class="card card-pad-0 review-fields-card">
                        <div class="card-head">
                            <div class="head-title"><Icon Name="sparkle" Size="20" /><h2>Extracted fields</h2></div>
                            <span class="pill tone-green">@CockpitFormat.PercentWhole(_detail.Confidence) overall</span>
                        </div>
                        <div class="field-editor">
                            @for (var i = 0; i < _fields.Count; i++)
                            {
                                var index = i;
                                var edit = _fields[index];
                                <div class="field-edit-row @(_activeField == edit.Name ? "is-active" : null)"
                                     @onmouseover="@(() => SetActive(edit))" @onfocusin="@(() => SetActive(edit))">
                                    <label class="field-edit-label" for="@($"field-{index}")">@edit.Name</label>
                                    <div class="field-edit-control">
                                        <input id="@($"field-{index}")" class="field-input @(edit.IsEdited ? "is-edited" : null)"
                                               value="@edit.Value" @oninput="e => OnFieldInput(index, e.Value?.ToString())"
                                               aria-label="@($"{edit.Name} value")" />
                                        <ConfidenceBadge Value="edit.Confidence" IsCorrected="edit.IsCorrected" />
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="card-actions review-field-actions">
                            <span>@EditedCount correction@(EditedCount == 1 ? "" : "s") staged</span>
                            <button class="btn btn-ghost" type="button" @onclick="LoadAsync" disabled="@_submitting"><Icon Name="sparkle" Size="16" /> Reset</button>
                        </div>
                    </article>
                }

                <article class="card card-pad-0 review-checks-card">
                    <div class="card-head">
                        <div class="head-title"><Icon Name="alert" Size="20" /><h2>Checks</h2></div>
                        <span class="pill @CockpitFormat.ExceptionTone(_detail.Exceptions.Count)">@_detail.Exceptions.Count</span>
                    </div>
                    <div class="checks-list">
                        @if (_detail.Exceptions.Count == 0)
                        {
                            <div class="empty-state compact-empty">
                                <span class="empty-ic"><Icon Name="check-circle" Size="34" /></span>
                                <h3>All checks passed</h3>
                                <p>Every stated value reconciles with the detail.</p>
                            </div>
                        }
                        else
                        {
                            @foreach (var issue in OrderedExceptions)
                            {
                                <div @onmouseover="@(() => SetActiveValue(issue.FieldName, issue.Detected))">
                                    <ExceptionCard Issue="issue" />
                                </div>
                            }
                        }
                    </div>
                </article>
            </div>
        </section>

        <section class="card review-decision-card">
            <div class="card-head">
                <div class="head-title"><Icon Name="check-circle" Size="20" /><h2>Review decision</h2></div>
                @if (EditedCount > 0)
                {
                    <span class="pill tone-violet">@EditedCount correction@(EditedCount == 1 ? "" : "s")</span>
                }
            </div>
            @if (!CanAct)
            {
                <p class="review-help">This document is unsupported and cannot be approved or exported. Import a supported document to continue.</p>
            }
            else
            {
                <div class="decision-form-grid">
                    <label class="decision-input-group" for="reviewer">
                        <span>Reviewer</span>
                        <input id="reviewer" class="field-input" @bind="_reviewer" aria-label="Reviewer name" />
                    </label>
                    <label class="decision-input-group" for="notes">
                        <span>Notes</span>
                        <input id="notes" class="field-input" @bind="_notes" placeholder="Optional review notes" aria-label="Review notes" />
                    </label>
                </div>
                <div class="row-actions review-decision-actions">
                    <button class="btn btn-primary" type="button" @onclick="ApproveAsync" disabled="@(_submitting || !CanSubmit)">
                        @if (_submitting) { <span class="spinner"></span> } else { <Icon Name="check" Size="16" /> }
                        Approve
                    </button>
                    <button class="btn btn-ghost" type="button" @onclick="RequestCorrectionAsync" disabled="@(_submitting || !CanSubmit)"><Icon Name="edit" Size="16" /> Request correction</button>
                    <button class="btn btn-ghost" type="button" @onclick="RejectAsync" disabled="@(_submitting || !CanSubmit)"><Icon Name="x-circle" Size="16" /> Reject</button>
                </div>
                @if (!CanSubmit)
                {
                    <p class="review-help">Enter a reviewer name to record a decision.</p>
                }
            }
        </section>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private readonly record struct Toast(string Kind, string Message);

    private sealed class FieldEdit
    {
        public string Name { get; init; } = "";
        public string Original { get; init; } = "";
        public string Value { get; set; } = "";
        public double Confidence { get; init; }
        public bool IsCorrected { get; init; }
        public bool IsEdited => !string.Equals(Value, Original, StringComparison.Ordinal);
    }

    private DocumentDetail? _detail;
    private List<FieldEdit> _fields = [];
    private List<ExportTemplate> _templates = [];
    private string _reviewer = "Underwriting Team";
    private string _notes = string.Empty;
    private bool _loading = true;
    private bool _submitting;
    private Toast? _toast;
    private DateTimeOffset _now = DateTimeOffset.UtcNow;

    private string? _activeField;
    private string? _activeValue;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private string ExportHref(string format) => $"api/documents/{Id}/export?format={format}";

    private string TemplateExportHref(Guid templateId) => $"api/documents/{Id}/export?templateId={templateId}";

    private async Task LoadAsync()
    {
        _loading = true;
        _now = DateTimeOffset.UtcNow;
        StateHasChanged();
        try
        {
            _detail = await Workflow.GetAsync(Id, CancellationToken.None);
            var defaultId = RuntimeSettings.Current.DefaultTemplateId;
            _templates = [.. (await Templates.ListAsync(CancellationToken.None)).OrderByDescending(template => template.Id == defaultId)];
            BindFields();
        }
        catch (Exception ex)
        {
            _toast = new Toast("err", $"Could not load document: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private void BindFields()
    {
        _fields = _detail is null
            ? []
            : [.. _detail.Fields.Select(extracted => new FieldEdit
            {
                Name = extracted.Name,
                Original = extracted.Value,
                Value = extracted.Value,
                Confidence = extracted.Confidence,
                IsCorrected = extracted.IsCorrected
            })];
    }

    private void OnFieldInput(int index, string? value)
    {
        if (index >= 0 && index < _fields.Count)
        {
            _fields[index].Value = value ?? string.Empty;
            SetActiveValue(_fields[index].Name, _fields[index].Value);
        }
    }

    private void SetActive(FieldEdit edit) => SetActiveValue(edit.Name, edit.Value);

    private void SetActiveValue(string? field, string? value)
    {
        _activeField = string.IsNullOrWhiteSpace(field) ? null : field;
        _activeValue = string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

    // The document text with the active field's value highlighted in place (the "citation").
    // The text is HTML-encoded first, so wrapping the encoded match in a mark tag is safe.
    private MarkupString HighlightedBody
    {
        get
        {
            var text = string.IsNullOrWhiteSpace(_detail?.ParsedMarkdown) ? "No preview text available." : _detail.ParsedMarkdown.Trim();
            const int limit = 4000;
            if (text.Length > limit)
            {
                text = text[..limit] + "\n…";
            }

            var encoded = System.Net.WebUtility.HtmlEncode(text);
            if (!string.IsNullOrWhiteSpace(_activeValue))
            {
                var needle = System.Net.WebUtility.HtmlEncode(_activeValue);
                var at = encoded.IndexOf(needle, StringComparison.OrdinalIgnoreCase);
                if (at >= 0)
                {
                    encoded = encoded[..at] + "<mark class=\"cite\">" + encoded.Substring(at, needle.Length) + "</mark>" + encoded[(at + needle.Length)..];
                }
            }

            return new MarkupString(encoded);
        }
    }

    private string? CiteClass(string cell) =>
        !string.IsNullOrWhiteSpace(_activeValue) && cell.Trim().Equals(_activeValue, StringComparison.OrdinalIgnoreCase) ? "cite" : null;

    private int EditedCount => _fields.Count(candidate => candidate.IsEdited);

    private bool CanAct => _detail is not null && CockpitFormat.IsActionable(_detail.Status);

    private bool ShowFields => CanAct && _fields.Count > 0;

    private bool CanSubmit => CanAct && !string.IsNullOrWhiteSpace(_reviewer);

    private IReadOnlyList<ExtractionIssue> OrderedExceptions => _detail is null
        ? []
        : [.. _detail.Exceptions
            .OrderByDescending(issue => issue.IsReconciliation)
            .ThenBy(issue => issue.Confidence)];

    private string AttentionTitle => _detail?.Status == DocumentStatus.Failed
        ? "Processing failed"
        : "Unsupported document — no fabricated fields";

    private string AttentionCopy => _detail?.Status == DocumentStatus.Failed
        ? "No trusted extraction was created, so export and approval stay locked."
        : "This file was not recognized as a reinsurance document. The upload and parse are kept for audit, but export and approval stay locked.";

    private Task ApproveAsync() => SubmitAsync("Approve");

    private Task RequestCorrectionAsync() => SubmitAsync("RequestCorrection");

    private Task RejectAsync() => SubmitAsync("Reject");

    private async Task SubmitAsync(string decision)
    {
        if (_detail is null || !CanSubmit)
        {
            return;
        }

        _submitting = true;
        _toast = null;
        StateHasChanged();
        try
        {
            var corrections = _fields
                .Where(candidate => candidate.IsEdited)
                .Select(candidate => new FieldCorrection(candidate.Name, candidate.Value))
                .ToList();

            var payload = new ReviewDecision(decision, _reviewer.Trim(),
                string.IsNullOrWhiteSpace(_notes) ? null : _notes.Trim(), corrections);

            var updated = await Workflow.ReviewAsync(Id, payload, CancellationToken.None);
            if (updated is null)
            {
                _toast = new Toast("err", "The review could not be saved.");
            }
            else
            {
                _detail = updated;
                _now = DateTimeOffset.UtcNow;
                BindFields();
                _toast = new Toast("ok", $"Decision recorded: {DecisionLabel(decision)}.");
            }
        }
        catch (Exception ex)
        {
            _toast = new Toast("err", $"Review failed: {ex.Message}");
        }
        finally
        {
            _submitting = false;
        }
    }

    private static string DecisionLabel(string decision) => decision switch
    {
        "RequestCorrection" => "correction requested",
        "Reject" => "rejected",
        _ => "approved"
    };
}
