@page "/settings"
@rendermode @(new InteractiveServerRenderMode(false))
@inject ISettingsStore Store
@inject IExportTemplateStore TemplateStore
@inject IDataMaintenance DataMaintenance
@inject NavigationManager Nav

<PageTitle>Settings · @Brand.Product</PageTitle>

<header class="cockpit-topbar cockpit-topbar-workbench">
    <div class="topbar-titles">
        <h1>Settings</h1>
        <p>Make @Brand.Product yours — theme, accent, branding, and how it behaves.</p>
    </div>
    <div class="topbar-tools">
        <button class="btn btn-primary" type="button" @onclick="SaveAsync" disabled="@_busy"><Icon Name="check" Size="18" /> Save changes</button>
    </div>
</header>

<div class="cockpit-content settings-content">
    @if (_toast is not null)
    {
        <div class="toast @_toast.Value.Kind" role="status">
            <Icon Name="@(_toast.Value.Kind == "ok" ? "check-circle" : "alert")" Size="18" />
            <span>@_toast.Value.Message</span>
        </div>
    }

    <section class="card settings-card">
        <div class="settings-section-head"><h2>Appearance</h2><p>Theme and accent apply across the whole app.</p></div>

        <div class="setting-row">
            <div class="setting-label"><strong>Theme</strong><span>Match your system or pick one.</span></div>
            <div class="seg-filter" role="group" aria-label="Theme">
                <button class="seg @(_theme == AppTheme.Light ? "is-on" : null)" type="button" @onclick="@(() => _theme = AppTheme.Light)">Light</button>
                <button class="seg @(_theme == AppTheme.Dark ? "is-on" : null)" type="button" @onclick="@(() => _theme = AppTheme.Dark)">Dark</button>
                <button class="seg @(_theme == AppTheme.System ? "is-on" : null)" type="button" @onclick="@(() => _theme = AppTheme.System)">System</button>
            </div>
        </div>

        <div class="setting-row">
            <div class="setting-label"><strong>Accent colour</strong><span>The one colour the app is built around.</span></div>
            <div class="swatches" role="group" aria-label="Accent colour">
                @foreach (var swatch in Swatches)
                {
                    <button type="button" class="swatch @(_accent == swatch.Value ? "is-on" : null)"
                            style="--swatch: @(string.IsNullOrEmpty(swatch.Value) ? "#0f766e" : swatch.Value)"
                            title="@swatch.Name" aria-label="@swatch.Name" @onclick="@(() => _accent = swatch.Value)">
                        @if (_accent == swatch.Value)
                        {
                            <Icon Name="check" Size="16" />
                        }
                    </button>
                }
            </div>
        </div>
    </section>

    <section class="card settings-card">
        <div class="settings-section-head"><h2>Branding</h2><p>The name shown across the app.</p></div>
        <div class="setting-row">
            <div class="setting-label"><strong>Product name</strong><span>Appears in the rail, titles, and headers.</span></div>
            <input class="field-input setting-input" @bind="_productName" @bind:event="oninput" maxlength="80" aria-label="Product name" />
        </div>
    </section>

    <section class="card settings-card">
        <div class="settings-section-head"><h2>Review</h2><p>How checks are scored and what export is the default.</p></div>

        <div class="setting-row">
            <div class="setting-label"><strong>Confidence tiers</strong><span>Below @Percent(_low) is Low, below @Percent(_medium) is Medium, the rest is High.</span></div>
            <div class="threshold-controls">
                <label>Low&nbsp;below <input type="range" min="0" max="1" step="0.05" @bind="_low" @bind:event="oninput" /> <b>@Percent(_low)</b></label>
                <label>Medium&nbsp;below <input type="range" min="0" max="1" step="0.05" @bind="_medium" @bind:event="oninput" /> <b>@Percent(_medium)</b></label>
            </div>
        </div>

        <div class="setting-row">
            <div class="setting-label"><strong>Default export template</strong><span>Offered first in the review Export menu.</span></div>
            <select class="field-input setting-input" @bind="_defaultTemplateId" aria-label="Default export template">
                <option value="">None</option>
                @foreach (var template in _templates)
                {
                    <option value="@template.Id">@template.Name</option>
                }
            </select>
        </div>
    </section>

    <section class="card settings-card">
        <div class="settings-section-head"><h2>Data</h2><p>Manage the documents in this workspace.</p></div>
        <div class="setting-row">
            <div class="setting-label"><strong>Demo corpus</strong><span>Load the sample documents (only when empty).</span></div>
            <button class="btn btn-ghost" type="button" @onclick="ReseedAsync" disabled="@_busy"><Icon Name="inbox" Size="16" /> Reseed demo</button>
        </div>
        <div class="setting-row">
            <div class="setting-label"><strong>Clear all documents</strong><span>Permanently delete every uploaded document.</span></div>
            @if (_confirmClear)
            {
                <div class="row-actions">
                    <button class="btn btn-ghost danger" type="button" @onclick="ClearAsync" disabled="@_busy"><Icon Name="x-circle" Size="16" /> Yes, delete everything</button>
                    <button class="btn btn-subtle" type="button" @onclick="@(() => _confirmClear = false)">Cancel</button>
                </div>
            }
            else
            {
                <button class="btn btn-ghost danger" type="button" @onclick="@(() => _confirmClear = true)" disabled="@_busy"><Icon Name="x-circle" Size="16" /> Clear all</button>
            }
        </div>
    </section>
</div>

@code {
    private readonly record struct Toast(string Kind, string Message);
    private readonly record struct Swatch(string Name, string Value);

    private static readonly Swatch[] Swatches =
    [
        new("Teal (default)", ""),
        new("Indigo", "#4f46e5"),
        new("Violet", "#7c3aed"),
        new("Blue", "#2563eb"),
        new("Emerald", "#059669"),
        new("Rose", "#e11d48"),
        new("Amber", "#d97706")
    ];

    private AppTheme _theme = AppTheme.Light;
    private string _accent = string.Empty;
    private string _productName = "Reve Intelligence";
    private double _low = 0.6;
    private double _medium = 0.85;
    private string _defaultTemplateId = string.Empty;
    private List<ExportTemplate> _templates = [];
    private bool _busy;
    private bool _confirmClear;
    private Toast? _toast;

    protected override async Task OnInitializedAsync()
    {
        var settings = await Store.GetAsync(CancellationToken.None);
        _theme = settings.Theme;
        _accent = settings.AccentColor;
        _productName = settings.ProductName;
        _low = settings.ConfidenceLowMax;
        _medium = settings.ConfidenceMediumMax;
        _defaultTemplateId = settings.DefaultTemplateId?.ToString() ?? string.Empty;
        _templates = [.. await TemplateStore.ListAsync(CancellationToken.None)];
    }

    private static string Percent(double value) => $"{value:P0}";

    private async Task SaveAsync()
    {
        _busy = true;
        try
        {
            Guid? defaultTemplate = Guid.TryParse(_defaultTemplateId, out var id) ? id : null;
            var settings = new AppSettings(_theme, _accent, _productName, _low, _medium, defaultTemplate);
            await Store.SaveAsync(settings, CancellationToken.None);
            // Reload so the new theme, accent, and branding take effect across the shell.
            Nav.NavigateTo("settings", forceLoad: true);
        }
        catch (Exception ex)
        {
            _toast = new Toast("err", $"Could not save: {ex.Message}");
            _busy = false;
        }
    }

    private async Task ReseedAsync()
    {
        _busy = true;
        try
        {
            var seeded = await DataMaintenance.ReseedDemoAsync(CancellationToken.None);
            _toast = new Toast(seeded ? "ok" : "err", seeded ? "Demo documents loaded." : "Workspace is not empty — clear it first.");
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ClearAsync()
    {
        _busy = true;
        _confirmClear = false;
        try
        {
            var removed = await DataMaintenance.ClearAllDocumentsAsync(CancellationToken.None);
            _toast = new Toast("ok", $"Deleted {removed} document{(removed == 1 ? "" : "s")}.");
        }
        finally
        {
            _busy = false;
        }
    }
}
